---
/**
 * Konami-code easter egg: a faux design-system inspector overlay.
 *
 * Sequence: ↑ ↑ ↓ ↓ ← → ← → b a
 *
 * Activates `[data-inspector]` on <html> which paints subtle dashed outlines,
 * tag-name badges on headings, and a corner toast with the legend. Esc closes.
 *
 * - prefers-reduced-motion: skip the entry animation
 * - keyboard: trap is purely additive — focus order is unchanged
 * - dismiss: Esc, the close button, or repeating the konami sequence
 * - announce: aria-live="polite" so SR users hear the state change
 */
---

<div
  id="inspector-toast"
  class="ix-toast"
  role="status"
  aria-live="polite"
  aria-hidden="true"
  hidden
>
  <div class="ix-toast-head">
    <span class="ix-toast-tag">
      <span class="ix-dot" aria-hidden="true"></span>
      Inspector mode
    </span>
    <button
      type="button"
      class="ix-close"
      data-ix-close
      aria-label="Close inspector mode (Esc)"
    >
      <iconify-icon icon="ph:x-bold" aria-hidden="true"></iconify-icon>
    </button>
  </div>
  <p class="ix-toast-lead">
    You found the secret&nbsp;mode. Welcome to the&nbsp;system.
  </p>
  <ul class="ix-legend" aria-label="Inspector legend">
    <li><span class="ix-swatch ix-swatch--plum"></span><span>Headings &amp; type scale</span></li>
    <li><span class="ix-swatch ix-swatch--coral"></span><span>Sections &amp; landmarks</span></li>
    <li><span class="ix-swatch ix-swatch--sky"></span><span>Buttons &amp; controls</span></li>
    <li><span class="ix-swatch ix-swatch--sage"></span><span>Cards &amp; surfaces</span></li>
  </ul>
  <p class="ix-toast-foot">
    <kbd>Esc</kbd> to close, or run the sequence again.
  </p>
</div>

<script>
  const SEQUENCE = [
    'ArrowUp', 'ArrowUp',
    'ArrowDown', 'ArrowDown',
    'ArrowLeft', 'ArrowRight',
    'ArrowLeft', 'ArrowRight',
    'b', 'a',
  ];

  const html = document.documentElement;
  const toast = document.getElementById('inspector-toast');
  const closeBtn = toast?.querySelector<HTMLButtonElement>('[data-ix-close]');

  let buffer: string[] = [];

  function isTypingTarget(el: EventTarget | null): boolean {
    if (!(el instanceof HTMLElement)) return false;
    const tag = el.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return true;
    if (el.isContentEditable) return true;
    return false;
  }

  function setActive(active: boolean) {
    if (active) {
      html.setAttribute('data-inspector', '');
      toast?.removeAttribute('hidden');
      toast?.setAttribute('aria-hidden', 'false');
      // small delay to let CSS transition kick in
      requestAnimationFrame(() => toast?.classList.add('is-on'));
    } else {
      toast?.classList.remove('is-on');
      toast?.setAttribute('aria-hidden', 'true');
      // hide after transition
      window.setTimeout(() => toast?.setAttribute('hidden', ''), 240);
      html.removeAttribute('data-inspector');
    }
  }

  function toggle() {
    setActive(!html.hasAttribute('data-inspector'));
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && html.hasAttribute('data-inspector')) {
      setActive(false);
      return;
    }
    if (isTypingTarget(e.target)) return;

    const key = e.key.length === 1 ? e.key.toLowerCase() : e.key;
    buffer.push(key);
    // keep only the most recent SEQUENCE.length keys
    if (buffer.length > SEQUENCE.length) buffer = buffer.slice(-SEQUENCE.length);
    if (buffer.length === SEQUENCE.length && buffer.every((k, i) => k === SEQUENCE[i])) {
      buffer = [];
      toggle();
    }
  });

  closeBtn?.addEventListener('click', () => setActive(false));
</script>

<style is:global>
  /* ============= TOAST ============= */
  .ix-toast {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 60;
    width: min(20rem, calc(100vw - 2rem));
    background: #fffdf9;
    border: 1px solid rgba(45, 43, 85, 0.12);
    border-radius: 14px;
    padding: 1rem 1.1rem 1.05rem;
    box-shadow:
      0 24px 50px -18px rgba(45, 43, 85, 0.4),
      0 0 0 1px rgba(108, 74, 182, 0.08);
    font-family: var(--font-dm-sans), system-ui, sans-serif;
    color: #2d2b55;
    opacity: 0;
    transform: translateY(-8px) scale(0.98);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }
  .ix-toast.is-on { opacity: 1; transform: translateY(0) scale(1); }

  .ix-toast-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .ix-toast-tag {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-space-grotesk), system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6c4ab6;
  }
  .ix-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #6c4ab6;
    box-shadow: 0 0 0 4px rgba(108, 74, 182, 0.18);
    animation: ix-pulse 1.6s ease-in-out infinite;
  }
  @keyframes ix-pulse { 50% { box-shadow: 0 0 0 8px rgba(108, 74, 182, 0); } }

  .ix-close {
    width: 28px; height: 28px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 50%;
    background: rgba(45, 43, 85, 0.06);
    color: #2d2b55;
    border: 0;
    cursor: pointer;
  }
  .ix-close:hover { background: rgba(232, 87, 61, 0.15); color: #e8573d; }
  .ix-close:focus-visible { outline: 2px dashed #6c4ab6; outline-offset: 3px; }

  .ix-toast-lead {
    font-family: var(--font-fraunces), Georgia, serif;
    font-weight: 600;
    font-size: 1.05rem;
    line-height: 1.3;
    margin: 0 0 0.7rem;
    color: #2d2b55;
  }
  .ix-legend {
    list-style: none; padding: 0; margin: 0 0 0.65rem;
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.35rem 0.6rem;
  }
  .ix-legend li {
    display: inline-flex; align-items: center; gap: 0.45rem;
    font-size: 0.78rem; color: #2e2e30;
  }
  .ix-swatch {
    width: 12px; height: 12px;
    border-radius: 3px;
    box-shadow: inset 0 0 0 1.5px currentColor;
  }
  .ix-swatch--plum  { color: #6c4ab6; }
  .ix-swatch--coral { color: #e8573d; }
  .ix-swatch--sky   { color: #1b6fa1; }
  .ix-swatch--sage  { color: #3e6e3d; }

  .ix-toast-foot {
    font-size: 0.72rem;
    color: rgba(45, 43, 85, 0.6);
    margin: 0.35rem 0 0;
  }
  .ix-toast kbd {
    font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
    font-size: 0.68rem;
    background: rgba(108, 74, 182, 0.1);
    color: #6c4ab6;
    padding: 1px 6px;
    border-radius: 4px;
    border: 1px solid rgba(108, 74, 182, 0.2);
  }

  @media (prefers-reduced-motion: reduce) {
    .ix-toast { transition: opacity 0.001s; transform: none !important; }
    .ix-dot { animation: none; }
  }

  /* ============= INSPECTOR OVERLAY ============= */
  /* Apply only when html[data-inspector] is set. Use outlines (no layout shift). */

  html[data-inspector] body { background: #fffaf0; }

  /* Headings — plum dashed outline + tag-name corner label */
  html[data-inspector] :is(h1, h2, h3, h4, h5, h6) {
    position: relative;
    outline: 1px dashed rgba(108, 74, 182, 0.55);
    outline-offset: 6px;
  }
  html[data-inspector] :is(h1, h2, h3, h4, h5, h6)::before {
    content: '';
    position: absolute;
    top: -0.6em;
    left: -0.2em;
    transform: translateY(-100%);
    background: #6c4ab6;
    color: #fff;
    font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 2px 6px;
    border-radius: 4px 4px 4px 0;
    text-transform: lowercase;
    pointer-events: none;
    line-height: 1.2;
    white-space: nowrap;
    z-index: 1;
  }
  html[data-inspector] h1::before { content: 'h1 · display'; }
  html[data-inspector] h2::before { content: 'h2 · section'; }
  html[data-inspector] h3::before { content: 'h3 · subsection'; }
  html[data-inspector] h4::before { content: 'h4'; }
  html[data-inspector] h5::before { content: 'h5'; }
  html[data-inspector] h6::before { content: 'h6'; }

  /* Sections — coral outline + landmark label */
  html[data-inspector] section,
  html[data-inspector] main,
  html[data-inspector] header,
  html[data-inspector] footer,
  html[data-inspector] nav,
  html[data-inspector] article {
    position: relative;
    outline: 1px dashed rgba(232, 87, 61, 0.45);
    outline-offset: -1px;
  }
  html[data-inspector] section::after,
  html[data-inspector] main::after,
  html[data-inspector] header::after,
  html[data-inspector] footer::after,
  html[data-inspector] nav::after,
  html[data-inspector] article::after {
    position: absolute;
    top: 0;
    right: 0;
    background: #e8573d;
    color: #fff;
    font-family: var(--font-jetbrains-mono), ui-monospace, monospace;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 2px 5px;
    border-radius: 0 0 0 4px;
    text-transform: lowercase;
    pointer-events: none;
    line-height: 1.2;
    z-index: 1;
  }
  html[data-inspector] section::after  { content: '<section>'; }
  html[data-inspector] main::after     { content: '<main>'; }
  html[data-inspector] header::after   { content: '<header>'; }
  html[data-inspector] footer::after   { content: '<footer>'; }
  html[data-inspector] nav::after      { content: '<nav>'; }
  html[data-inspector] article::after  { content: '<article>'; }

  /* Buttons & controls — sky outline */
  html[data-inspector] button,
  html[data-inspector] [role='button'],
  html[data-inspector] a[href]:not([href='']) {
    outline: 1px dashed rgba(27, 111, 161, 0.55);
    outline-offset: 3px;
  }

  /* Don't double-outline the inspector toast itself */
  html[data-inspector] .ix-toast,
  html[data-inspector] .ix-toast *,
  html[data-inspector] .ix-toast *::before,
  html[data-inspector] .ix-toast *::after { outline: none !important; }
  html[data-inspector] .ix-toast :is(h1,h2,h3,h4,h5,h6)::before { content: none !important; }
</style>
