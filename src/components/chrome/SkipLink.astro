---
interface Props {
  href?: string;
  label?: string;
}

const { href = '#main', label = 'Skip to main content' } = Astro.props;
---

<a
  href={href}
  class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-plum focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:outline-none focus:shadow-lg"
>
  {label}
</a>
