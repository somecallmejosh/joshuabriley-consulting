---
import { cx } from '~/lib/cx';

interface Props {
  name: string;
  value: string;
  label: string;
  checked?: boolean;
  disabled?: boolean;
  /** When true, the choice fills the available width (used in stack layout). */
  block?: boolean;
  class?: string;
}

const {
  name,
  value,
  label,
  checked = false,
  disabled = false,
  block = false,
  class: className,
} = Astro.props;

const id = `choice-${name}-${value}`;
---

<label
  for={id}
  class={cx(
    'cursor-pointer select-none px-5 py-2 rounded-full font-heading text-sm transition-colors',
    'text-navy/70 has-[:checked]:bg-sage-deep has-[:checked]:text-white has-[:checked]:font-medium has-[:checked]:shadow-sm',
    'has-[:focus-visible]:outline has-[:focus-visible]:outline-2 has-[:focus-visible]:outline-offset-2 has-[:focus-visible]:outline-coral',
    'has-[:disabled]:opacity-50 has-[:disabled]:cursor-not-allowed',
    block && 'block w-full text-center',
    className,
  )}
>
  <input
    type="radio"
    id={id}
    name={name}
    value={value}
    checked={checked}
    disabled={disabled}
    class="sr-only"
  />
  {label}
</label>
