---
import { cx } from '~/lib/cx';

/**
 * Fieldset of radio pills. Renders a semantic <fieldset>/<legend> so screen
 * readers announce the question for each option.
 */

interface Props {
  legend: string;
  name: string;
  /** Visually hide the legend (still announced). */
  hideLegend?: boolean;
  /** Visual layout of the children. */
  layout?: 'pill' | 'stack';
  required?: boolean;
  hint?: string;
  error?: string;
  class?: string;
}

const {
  legend,
  name,
  hideLegend = false,
  layout = 'pill',
  required = false,
  hint,
  error,
  class: className,
} = Astro.props;

const baseId = `choicegroup-${name}`;
const hintId = hint ? `${baseId}-hint` : undefined;
const errorId = error ? `${baseId}-error` : undefined;
const describedBy = [hintId, errorId].filter(Boolean).join(' ') || undefined;
---

<fieldset
  class={cx('flex flex-col gap-3', className)}
  data-choicegroup-name={name}
  data-choicegroup-described-by={describedBy}
  data-choicegroup-required={required ? 'true' : undefined}
>
  <legend class={cx('font-heading text-sm font-medium text-navy', hideLegend && 'sr-only')}>
    {legend}
    {required && <span aria-hidden="true" class="text-coral ml-0.5">*</span>}
  </legend>

  <div
    class={cx(
      layout === 'pill'
        ? 'inline-flex flex-wrap gap-2 bg-white p-1.5 rounded-full border border-charcoal/60 self-start'
        : 'flex flex-col gap-2',
    )}
  >
    <slot />
  </div>

  {hint && <p id={hintId} class="text-xs text-charcoal/70">{hint}</p>}
  {error && (
    <p id={errorId} role="alert" class="text-xs text-plum">{error}</p>
  )}
</fieldset>
