---
import Icon from '~/components/primitives/Icon.astro';
import { cx } from '~/lib/cx';

export interface SelectOption {
  value: string;
  label: string;
  disabled?: boolean;
}

interface Props {
  name: string;
  id?: string;
  options: SelectOption[];
  value?: string;
  /** Empty placeholder option label. */
  placeholder?: string;
  required?: boolean;
  invalid?: boolean;
  describedBy?: string;
  class?: string;
}

const {
  name,
  id,
  options,
  value,
  placeholder,
  required = false,
  invalid = false,
  describedBy,
  class: className,
} = Astro.props;

const fieldId = id ?? `field-${name}`;
---

<div class={cx('relative', className)}>
  <select
    id={fieldId}
    name={name}
    required={required}
    aria-required={required ? 'true' : undefined}
    aria-invalid={invalid ? 'true' : undefined}
    aria-describedby={describedBy}
    class="appearance-none w-full bg-white border border-charcoal/60 rounded-lg px-4 py-3 pr-10 font-body text-sm text-charcoal focus:border-plum aria-[invalid=true]:border-plum"
  >
    {placeholder && <option value="" disabled selected={!value}>{placeholder}</option>}
    {options.map((opt) => (
      <option value={opt.value} disabled={opt.disabled} selected={value === opt.value}>
        {opt.label}
      </option>
    ))}
  </select>
  <span aria-hidden="true" class="absolute right-3 top-1/2 -translate-y-1/2 text-charcoal/70 pointer-events-none">
    <Icon name="ph:caret-down-bold" size={16} />
  </span>
</div>
