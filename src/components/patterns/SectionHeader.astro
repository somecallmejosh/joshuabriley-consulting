---
import Heading from '~/components/primitives/Heading.astro';
import Text from '~/components/primitives/Text.astro';
import Badge from '~/components/primitives/Badge.astro';
import type { Tone } from '~/lib/tones';
import { cx } from '~/lib/cx';

interface Props {
  /** Eyebrow text rendered as a Badge. */
  eyebrow?: string;
  eyebrowIcon?: string;
  eyebrowTone?: Tone;
  title: string;
  /** Optional lead paragraph. */
  lead?: string;
  align?: 'center' | 'left';
  level?: 2 | 3;
  tone?: 'navy' | 'white';
  class?: string;
}

const {
  eyebrow,
  eyebrowIcon,
  eyebrowTone = 'plum',
  title,
  lead,
  align = 'center',
  level = 2,
  tone = 'navy',
  class: className,
} = Astro.props;
---

<div class={cx(align === 'center' && 'text-center', className)}>
  {eyebrow && (
    <div class={cx('mb-5', align === 'center' && 'inline-block')}>
      <Badge tone={eyebrowTone} icon={eyebrowIcon}>{eyebrow}</Badge>
    </div>
  )}
  <Heading level={level} visual={level === 2 ? 'display-md' : 'h2'} tone={tone} align={align} balance>
    {title}
  </Heading>
  {lead && (
    <Text
      size="xl"
      tone={tone === 'white' ? 'whiteMuted' : 'muted'}
      align={align}
      class={cx('mt-4', align === 'center' && 'max-w-2xl mx-auto')}
    >
      {lead}
    </Text>
  )}
</div>
