---
import Icon from '~/components/primitives/Icon.astro';
import { cx } from '~/lib/cx';

/**
 * Polaroid wrapper for a project card on the corkboard. Provides the white
 * mat, pin/tape decorations, and the standard footer (label badge + marker
 * number + title + summary + arrow CTA). The collage interior is supplied via
 * the default slot — page-level composition because every project's collage
 * is bespoke (gradient, logo SVG, stickers, stat badge).
 */

type Tone = 'coral' | 'plum' | 'sage' | 'sky' | 'navy';
type Decoration = 'pin' | 'tape-l' | 'tape-r' | 'tape-both';

interface Props {
  href: string;
  title: string;
  summary: string;
  cta: string;
  /** Eyebrow label text. */
  label: string;
  labelTone: Tone;
  labelIcon: string;
  /** Marker number, e.g. "01". */
  marker: string;
  /** CSS rotation, e.g. "-1.8deg". */
  tilt: string;
  /** Tilt direction for the eyebrow sticker (signed degrees). */
  labelTilt?: string;
  decoration?: Decoration;
  class?: string;
}

const {
  href,
  title,
  summary,
  cta,
  label,
  labelTone,
  labelIcon,
  marker,
  tilt,
  labelTilt = '-1.5deg',
  decoration = 'pin',
  class: className,
} = Astro.props;

const labelToneClass: Record<Tone, string> = {
  coral: 'bg-coral/10 text-coral border-coral/30',
  plum: 'bg-plum/10 text-plum border-plum/30',
  sage: 'bg-sage/20 text-sage border-sage/40',
  sky: 'bg-sky/15 text-sky border-sky/40',
  navy: 'bg-navy/10 text-navy border-navy/30',
};
---

<article class={cx('polaroid', className)} style={`transform: rotate(${tilt})`}>
  {decoration === 'pin' && <span class="pin" aria-hidden="true" />}
  {(decoration === 'tape-l' || decoration === 'tape-both') && <span class="tape tape-l" aria-hidden="true" />}
  {(decoration === 'tape-r' || decoration === 'tape-both') && <span class="tape tape-r" aria-hidden="true" />}

  <a href={href} class="block group">
    <div class="collage">
      <slot />
    </div>
    <div class="pt-5 px-1">
      <div class="flex items-center justify-between mb-2 gap-3">
        <span
          class={cx(
            'sticker inline-flex items-center',
            labelToneClass[labelTone],
          )}
          style={`transform: rotate(${labelTilt})`}
        >
          <Icon name={labelIcon} size={14} class="mr-1" />
          {label}
        </span>
        <span class="marker-label">{marker}</span>
      </div>
      <h2
        class="font-display text-2xl md:text-[1.7rem] font-semibold text-navy leading-tight mb-3 group-hover:text-coral transition-colors"
      >
        {title}
      </h2>
      <p class="text-charcoal/70 text-base leading-relaxed mb-4">
        {summary}
      </p>
      <span class="inline-flex items-center gap-1.5 font-heading text-sm font-semibold text-coral">
        {cta}
        <Icon name="ph:arrow-right-bold" size={16} class="group-hover:translate-x-1 transition-transform" />
      </span>
    </div>
  </a>
</article>

<style>
  .polaroid {
    background: #fff;
    padding: 14px 14px 20px;
    border-radius: 10px;
    box-shadow:
      0 18px 40px -18px rgba(45, 43, 85, 0.25),
      0 2px 4px rgba(45, 43, 85, 0.06);
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease;
    position: relative;
  }
  .polaroid:hover {
    transform: translateY(-6px) rotate(0deg) !important;
    box-shadow:
      0 30px 60px -20px rgba(108, 74, 182, 0.28),
      0 0 0 1px rgba(108, 74, 182, 0.08);
  }
  .polaroid :global(.collage) {
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    padding: 16px;
  }
  .polaroid :global(.collage__bg) {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .polaroid :global(.collage__logo) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-2deg);
    background: #fff;
    border-radius: 14px;
    padding: 28px 34px;
    box-shadow:
      0 22px 44px -18px rgba(45, 43, 85, 0.4),
      0 4px 10px -4px rgba(45, 43, 85, 0.12),
      0 0 0 1px rgba(45, 43, 85, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 4;
    min-width: 48%;
    max-width: 72%;
  }
  .polaroid :global(.collage__logo svg) {
    max-height: 72px;
    max-width: 100%;
    width: auto;
    height: auto;
  }
  .polaroid:hover :global(.collage__logo) {
    transform: translate(-50%, -50%) rotate(0deg) scale(1.03);
    transition: transform 0.35s ease;
  }
  .polaroid :global(.collage__sticker) {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 9999px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    border: 1.5px dashed;
    z-index: 3;
  }
  .polaroid :global(.collage__tape) {
    position: absolute;
    width: 58px;
    height: 16px;
    background: rgba(253, 230, 138, 0.92);
    box-shadow: 0 2px 4px -1px rgba(0, 0, 0, 0.12);
    z-index: 1;
  }
  .polaroid :global(.collage__doodle) {
    position: absolute;
    z-index: 2;
    opacity: 0.7;
  }
  .polaroid :global(.collage__stat) {
    position: absolute;
    background: #fff;
    border-radius: 10px;
    padding: 8px 12px;
    box-shadow: 0 6px 14px -6px rgba(45, 43, 85, 0.25);
    font-family: 'Fraunces', serif;
    z-index: 3;
    line-height: 1;
    text-align: center;
  }
  .polaroid :global(.collage__stat-num) {
    font-size: 1.4rem;
    font-weight: 700;
    color: #2d2b55;
  }
  .polaroid :global(.collage__stat-label) {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(45, 43, 85, 0.6);
    font-weight: 500;
    margin-top: 2px;
  }
  .polaroid :global(.tape.tape-l) {
    top: -14px;
    left: 8%;
    width: 90px;
    height: 22px;
    transform: rotate(-6deg);
    background: rgba(253, 230, 138, 0.88);
    box-shadow: 0 2px 6px -2px rgba(0, 0, 0, 0.15);
    z-index: 5;
  }
  .polaroid :global(.tape.tape-r) {
    top: -14px;
    right: 8%;
    width: 90px;
    height: 22px;
    transform: rotate(5deg);
    background: rgba(253, 230, 138, 0.88);
    box-shadow: 0 2px 6px -2px rgba(0, 0, 0, 0.15);
    z-index: 5;
  }
</style>
