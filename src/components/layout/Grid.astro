---
import { cx } from '~/lib/cx';

interface Props {
  /** Column count at the largest breakpoint; smaller breakpoints scale down. */
  cols?: 1 | 2 | 3 | 4;
  gap?: 'sm' | 'md' | 'lg';
  as?: 'div' | 'ul' | 'ol';
  class?: string;
}

const { cols = 3, gap = 'md', as: Tag = 'div', class: className } = Astro.props;

const colsMap: Record<NonNullable<Props['cols']>, string> = {
  1: 'grid-cols-1',
  2: 'grid-cols-1 sm:grid-cols-2',
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4',
};

const gaps: Record<NonNullable<Props['gap']>, string> = {
  sm: 'gap-4',
  md: 'gap-5',
  lg: 'gap-8',
};
---

<Tag class={cx('grid', colsMap[cols], gaps[gap], className)}>
  <slot />
</Tag>
