---
import { cx } from '~/lib/cx';

/**
 * Polymorphic heading. `level` controls the semantic tag (h1–h6); `visual`
 * controls size/weight independently so visual hierarchy never breaks the
 * document outline.
 */
type HeadingLevel = 1 | 2 | 3 | 4 | 5 | 6;
type HeadingVisual = 'display-xl' | 'display-lg' | 'display-md' | 'h1' | 'h2' | 'h3' | 'h4' | 'eyebrow';

interface Props {
  level: HeadingLevel;
  visual?: HeadingVisual;
  tone?: 'navy' | 'white' | 'plum' | 'coral';
  align?: 'left' | 'center';
  balance?: boolean;
  class?: string;
  id?: string;
}

const {
  level,
  visual,
  tone = 'navy',
  align = 'left',
  balance = false,
  class: className,
  id,
} = Astro.props;

const resolvedVisual: HeadingVisual = visual ?? (`h${level}` as HeadingVisual);
const Tag: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6' = `h${level}` as any;

const visualStyles: Record<HeadingVisual, string> = {
  'display-xl':
    'font-display text-5xl sm:text-6xl md:text-7xl font-semibold leading-[1.05] tracking-tight',
  'display-lg':
    'font-display text-4xl sm:text-5xl md:text-6xl font-semibold leading-[1.1] tracking-tight',
  'display-md':
    'font-display text-3xl sm:text-4xl md:text-5xl font-semibold leading-[1.15] tracking-tight',
  h1: 'font-display text-4xl md:text-5xl font-semibold leading-tight',
  h2: 'font-display text-3xl md:text-4xl font-semibold leading-tight',
  h3: 'font-heading text-xl md:text-2xl font-semibold leading-snug',
  h4: 'font-heading text-lg font-semibold leading-snug',
  eyebrow:
    'font-heading text-xs font-medium uppercase tracking-[0.18em]',
};

const tones: Record<NonNullable<Props['tone']>, string> = {
  navy: 'text-navy',
  white: 'text-white',
  plum: 'text-plum',
  coral: 'text-plum',
};
---

<Tag
  id={id}
  class={cx(
    visualStyles[resolvedVisual],
    tones[tone],
    align === 'center' && 'text-center',
    balance && 'text-balance',
    className,
  )}
>
  <slot />
</Tag>
