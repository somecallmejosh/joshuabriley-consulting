---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/layout/Section.astro';
import Container from '~/components/layout/Container.astro';
import Heading from '~/components/primitives/Heading.astro';
import Text from '~/components/primitives/Text.astro';
import Badge from '~/components/primitives/Badge.astro';
import Button from '~/components/primitives/Button.astro';
import Icon from '~/components/primitives/Icon.astro';
import Blob from '~/components/decorative/Blob.astro';
import WavyUnderline from '~/components/decorative/WavyUnderline.astro';
import SquiggleDivider from '~/components/decorative/SquiggleDivider.astro';
import Card from '~/components/card/Card.astro';
import CardGrid from '~/components/patterns/CardGrid.astro';
import CTABanner from '~/components/patterns/CTABanner.astro';
import SectionHeader from '~/components/patterns/SectionHeader.astro';
import TestimonialPinboard from '~/components/patterns/TestimonialPinboard.astro';
import TestimonialCard from '~/components/patterns/TestimonialCard.astro';

const description =
  "A custom design-to-code workflow for product teams. Stop losing sprints to handoff friction, rebuilt UI, and 'is this right?' — get a repeatable process your designers and engineers will actually follow.";

// "This is for you if…" cards
const forYouSignals = [
  {
    icon: 'ph:arrows-left-right-duotone',
    tone: 'coral',
    tilt: -1 as const,
    body: 'Figma-to-code handoff creates friction every single sprint.',
  },
  {
    icon: 'ph:git-diff-duotone',
    tone: 'plum',
    tilt: 1 as const,
    body: "What gets built doesn't match what was designed.",
  },
  {
    icon: 'ph:palette-duotone',
    tone: 'sunset',
    tilt: 0 as const,
    body: 'Design tokens exist — but nobody uses them consistently.',
  },
  {
    icon: 'ph:users-three-duotone',
    tone: 'sage',
    tilt: 1 as const,
    body: 'Designers and engineers are out of sync more often than not.',
  },
  {
    icon: 'ph:arrows-clockwise-duotone',
    tone: 'sky',
    tilt: 0 as const,
    span: true,
    body: "The same UI questions come up sprint after sprint — and you're tired of answering them.",
  },
];

const signalToneMap: Record<string, { iconClass: string; iconBg: string }> = {
  coral: { iconClass: 'text-coral', iconBg: 'bg-coral/10' },
  plum: { iconClass: 'text-plum', iconBg: 'bg-plum/10' },
  sunset: { iconClass: 'text-sunset', iconBg: 'bg-sunset/10' },
  sage: { iconClass: 'text-sage', iconBg: 'bg-sage/20' },
  sky: { iconClass: 'text-sky', iconBg: 'bg-sky/20' },
};

// Deliverables — six cards (last one is featured navy/plum)
const deliverables = [
  {
    icon: 'ph:magnifying-glass-duotone',
    accent: 'coral',
    title: "A clear view of where it's breaking",
    body: 'An honest assessment of your current workflow — the handoffs, the gaps, and the moments where trust falls apart.',
    tilt: -1 as const,
  },
  {
    icon: 'ph:flow-arrow-duotone',
    accent: 'plum',
    title: 'A custom design-to-code process',
    body: 'Not a generic template. A flow designed around your tools, your people, and the way your team already works.',
    tilt: 0 as const,
  },
  {
    icon: 'ph:handshake-duotone',
    accent: 'sunset',
    title: 'Defined team expectations',
    body: "Who owns what, when, and to what standard — so nobody's guessing whose job it is to catch the gap.",
    tilt: 0 as const,
  },
  {
    icon: 'ph:repeat-duotone',
    accent: 'sage',
    title: 'A repeatable sprint rhythm',
    body: 'A cadence your team can run every sprint — without reinventing handoff rituals each time.',
    tilt: 1 as const,
  },
  {
    icon: 'ph:check-square-duotone',
    accent: 'sky',
    title: 'A shared definition of "done"',
    body: 'One that designers and engineers actually agree on — before the ticket ever hits QA.',
    tilt: -1 as const,
  },
];

const deliverableAccentMap: Record<string, { text: string; bg: string; ring: string }> = {
  coral: { text: 'text-coral', bg: 'bg-coral/10', ring: 'bg-coral/5' },
  plum: { text: 'text-plum', bg: 'bg-plum/10', ring: 'bg-plum/5' },
  sunset: { text: 'text-sunset', bg: 'bg-sunset/10', ring: 'bg-sunset/10' },
  sage: { text: 'text-sage', bg: 'bg-sage/20', ring: 'bg-sage/10' },
  sky: { text: 'text-sky', bg: 'bg-sky/15', ring: 'bg-sky/10' },
};

// What's included — six list rows
const included = [
  {
    icon: 'ph:clipboard-text-duotone',
    accent: 'coral',
    title: 'Process audit',
    body: 'A grounded look at how your team actually hands work from design to code today — not the version on the wiki.',
  },
  {
    icon: 'ph:figma-logo-duotone',
    accent: 'plum',
    title: 'Figma structure review',
    body: 'How your files, components, and variables are set up — and where that structure is fighting the engineers downstream.',
  },
  {
    icon: 'ph:warning-octagon-duotone',
    accent: 'sunset',
    title: 'Breakdown point identification',
    body: 'The exact moments in your sprint where things go sideways — named, mapped, and tied back to root cause.',
  },
  {
    icon: 'ph:plugs-connected-duotone',
    accent: 'sage',
    title: 'Code Connect setup',
    body: 'Wire your Figma components to the real ones in your codebase so what designers place is what engineers ship.',
  },
  {
    icon: 'ph:book-bookmark-duotone',
    accent: 'sky',
    title: 'Custom workflow guide',
    body: 'A written playbook of your new design-to-code flow — short, specific, and built to be used by your whole team.',
  },
  {
    icon: 'ph:chalkboard-teacher-duotone',
    accent: 'lemon',
    title: '60-minute implementation session',
    body: 'A live working session where we roll the workflow out with your team, answer questions, and make sure it sticks.',
  },
];

const includedIconMap: Record<string, { bg: string; text: string }> = {
  coral: { bg: 'bg-coral/10', text: 'text-coral' },
  plum: { bg: 'bg-plum/10', text: 'text-plum' },
  sunset: { bg: 'bg-sunset/10', text: 'text-sunset' },
  sage: { bg: 'bg-sage/20', text: 'text-sage' },
  sky: { bg: 'bg-sky/15', text: 'text-sky' },
  lemon: { bg: 'bg-lemon/60', text: 'text-navy' },
};

// Process — four steps
const process = [
  {
    n: '01',
    tone: 'coral',
    title: 'Kickoff discussion',
    body: "We talk about what's really happening in your sprints — the friction, the frustrations, the workarounds your team has quietly invented.",
    tilt: -1 as const,
  },
  {
    n: '02',
    tone: 'plum',
    title: 'Audit review',
    body: "I dig into your Figma, your repo, and your process. I come back with what's working, what's breaking, and where the real leverage is.",
    tilt: 1 as const,
  },
  {
    n: '03',
    tone: 'sunset',
    title: 'Workflow guide creation',
    body: 'I write the new process — specific to your tools, your team, and your cadence. Not a theoretical framework; a thing you can run on Monday.',
    tilt: 0 as const,
  },
  {
    n: '04',
    tone: 'sage',
    title: 'Implementation session',
    body: 'We meet live, walk the team through the new flow, and run it together on real work — so it lands in practice, not just in a doc.',
    tilt: 1 as const,
  },
];

const stepBgMap: Record<string, string> = {
  coral: 'bg-coral shadow-coral/20',
  plum: 'bg-plum shadow-plum/20',
  sunset: 'bg-sunset shadow-sunset/20',
  sage: 'bg-sage shadow-sage/20',
};
---

<BaseLayout
  title="Design-to-Code Workflow — Joshua Briley | Design Systems Consulting"
  description={description}
>
  {/* HERO */}
  <Section tone="cream" padding="loose" decorated class="pt-16 md:pt-24">
    <div class="absolute inset-0 dot-paper opacity-70" aria-hidden="true"></div>
    <div class="absolute inset-x-0 top-0 h-48 bg-gradient-to-b from-cream via-cream to-transparent" aria-hidden="true"></div>
    <div class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-t from-cream to-transparent" aria-hidden="true"></div>

    <Blob tone="sunset" size="md" class="absolute top-24 right-[10%]" opacity="opacity-25" />
    <Blob tone="sky" size="sm" class="absolute top-44 left-[8%] rounded-full" animate="float-delay" opacity="opacity-40" />
    <Blob tone="sage" size="sm" class="absolute bottom-28 right-[16%]" animate="float-slow" opacity="opacity-30" />
    <Blob tone="lemon" size="sm" class="absolute bottom-36 left-[14%] rounded-full" animate="float" opacity="opacity-70" />

    <Container class="relative z-10">
      {/* Breadcrumb */}
      <nav class="flex items-center gap-2 text-sm font-heading text-charcoal/60 mb-10" aria-label="Breadcrumb">
        <a href="/services/" class="hover:text-coral transition-colors inline-flex items-center gap-1.5">
          <Icon name="ph:arrow-left-duotone" size={16} />
          All services
        </a>
        <span aria-hidden="true">/</span>
        <span class="text-charcoal/80">Design-to-Code Workflow</span>
      </nav>

      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-7">
          <div class="mb-8 inline-block">
            <Badge tone="peach" icon="ph:flow-arrow-duotone">For teams stuck in handoff loops</Badge>
          </div>

          <Heading level={1} visual="display-xl" class="mb-6">
            Stop losing sprints to design-to-code <WavyUnderline>friction</WavyUnderline>.
          </Heading>

          <p class="font-display text-xl md:text-2xl text-navy/80 italic mb-6 leading-snug">
            A custom workflow your designers and engineers will actually run.
          </p>

          <Text size="lg" tone="muted" class="max-w-xl mb-10">
            If every sprint feels like rebuilding UI, rechecking Figma, and second-guessing decisions —
            <strong class="text-charcoal font-semibold">the problem isn't people, it's process</strong>. Let's fix that.
          </Text>

          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <Button variant="primary" size="lg" iconLeft="ph:calendar-check-duotone" href="https://calendly.com/josh-thebrileys/30min/">
              Book an intro call
            </Button>
            <Button variant="ghost" size="lg" iconLeft="ph:arrow-down-duotone" href="#deliverables">
              See what you get
            </Button>
          </div>

          <div class="flex items-center gap-4 mt-10 text-sm font-heading text-charcoal/60">
            <span class="inline-flex items-center gap-1.5">
              <Icon name="ph:clock-duotone" size={18} class="text-plum" />
              ~3 week engagement
            </span>
            <span class="w-1 h-1 rounded-full bg-charcoal/30" aria-hidden="true"></span>
            <span class="inline-flex items-center gap-1.5">
              <Icon name="ph:currency-dollar-duotone" size={18} class="text-plum" />
              Starting at $2,500
            </span>
          </div>
        </div>

        {/* Handoff-bridge visual */}
        <div class="lg:col-span-5 relative h-[420px] md:h-[480px] hidden lg:block" aria-hidden="true">
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-80 h-80 rounded-full border-2 border-dashed border-plum/25 animate-spin-slow"></div>
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-60 h-60 rounded-full bg-sunset/10 animate-pulse-ring"></div>
          </div>

          {/* Design node */}
          <div class="absolute top-[18%] left-[2%] bg-white rounded-2xl shadow-xl border border-charcoal/5 p-4 w-40 animate-float -rotate-3">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-7 h-7 rounded-lg bg-plum/15 flex items-center justify-center">
                <Icon name="ph:figma-logo-duotone" size={18} class="text-plum" />
              </div>
              <span class="font-heading text-xs font-semibold text-navy">Design</span>
            </div>
            <div class="space-y-1.5">
              <div class="h-1.5 rounded-full bg-charcoal/10"></div>
              <div class="h-1.5 rounded-full bg-charcoal/10 w-4/5"></div>
              <div class="h-1.5 rounded-full bg-coral/40 w-3/5"></div>
            </div>
          </div>

          {/* Code node */}
          <div class="absolute bottom-[18%] right-[2%] bg-white rounded-2xl shadow-xl border border-charcoal/5 p-4 w-40 animate-float-delay rotate-3">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-7 h-7 rounded-lg bg-sunset/15 flex items-center justify-center">
                <Icon name="ph:code-duotone" size={18} class="text-sunset" />
              </div>
              <span class="font-heading text-xs font-semibold text-navy">Code</span>
            </div>
            <div class="font-mono text-[10px] text-charcoal/70 leading-relaxed">
              <div>&lt;Button</div>
              <div class="pl-2 text-coral">variant="primary"</div>
              <div>/&gt;</div>
            </div>
          </div>

          {/* Flowing connection */}
          <svg class="absolute inset-0 w-full h-full" viewBox="0 0 400 480" fill="none">
            <path
              d="M 110 150 C 180 200, 220 280, 290 340"
              stroke="#6C4AB6"
              stroke-width="3"
              stroke-linecap="round"
              style="stroke-dasharray: 10 8; animation: dash-flow 1.6s linear infinite"
            />
            <circle cx="110" cy="150" r="5" fill="#6C4AB6" />
            <circle cx="290" cy="340" r="5" fill="#E8573D" />
          </svg>

          {/* Token chip */}
          <div class="absolute top-[44%] left-[38%] bg-white rounded-full shadow-lg border border-charcoal/5 px-3 py-1.5 flex items-center gap-1.5 animate-slide-chip">
            <div class="w-2.5 h-2.5 rounded-full bg-coral"></div>
            <span class="font-heading text-[11px] font-semibold text-navy">token.color.primary</span>
          </div>

          {/* Sticky note */}
          <div class="absolute top-[6%] right-[8%] bg-lemon/90 rounded-lg shadow-md p-2 w-24 animate-float-slow rotate-6">
            <div class="h-1 rounded bg-navy/30 mb-1"></div>
            <div class="h-1 rounded bg-navy/30 w-3/4"></div>
          </div>

          {/* Spec check */}
          <div class="absolute bottom-[4%] left-[18%] bg-white rounded-xl shadow-lg border border-charcoal/5 p-2.5 flex items-center gap-2 animate-float -rotate-2">
            <Icon name="ph:check-circle-duotone" size={18} class="text-sage" />
            <span class="font-heading text-[11px] font-semibold text-navy">Spec matches</span>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <SquiggleDivider />

  {/* THIS IS FOR YOU IF */}
  <Section padding="default">
    <Container>
      <SectionHeader
        eyebrow="This is for you if…"
        eyebrowIcon="ph:hand-waving-duotone"
        eyebrowTone="plum"
        title="Handoff keeps eating your sprint"
        lead="Adding more annotations, specs, and comments hasn't fixed it. It's not an information problem — it's a workflow one."
        class="mb-14"
      />

      <CardGrid cols={2} gap="md">
        {forYouSignals.map((s) => {
          const t = signalToneMap[s.tone];
          return (
            <Card variant="paper" tilt={s.tilt} class={s.span ? 'sm:col-span-2 flex gap-4' : 'flex gap-4'}>
              <div class={`w-12 h-12 ${t.iconBg} rounded-xl flex items-center justify-center flex-shrink-0`}>
                <Icon name={s.icon} size={24} class={t.iconClass} />
              </div>
              <p class="font-heading font-medium text-navy self-center">{s.body}</p>
            </Card>
          );
        })}
      </CardGrid>
    </Container>
  </Section>

  {/* PHILOSOPHY CALLOUT */}
  <Section padding="tight" class="bg-charcoal/[0.03]">
    <Container width="narrow">
      <Card variant="paper" tilt={0} padding="loose" class="relative overflow-hidden -rotate-[0.3deg]">
        <Blob tone="sunset" size="xl" class="absolute -top-10 -right-10" animate="float-slow" opacity="opacity-30" />
        <Blob tone="plum" size="lg" class="absolute -bottom-8 -left-8 rounded-full" animate="float-delay" opacity="opacity-20" />

        <div class="relative">
          <Icon name="ph:quotes-duotone" size={48} class="text-coral/60 mb-4" />
          <p class="font-display text-2xl md:text-3xl lg:text-4xl text-navy leading-[1.3] font-medium mb-6">
            More annotations. More specs. More comments.
            <span class="italic">That doesn't solve the problem.</span>
          </p>
          <p class="font-display text-xl md:text-2xl text-coral leading-snug italic">
            The fix isn't more information — it's a workflow you can actually run.
          </p>
        </div>
      </Card>
    </Container>
  </Section>

  {/* DELIVERABLES */}
  <Section id="deliverables" padding="default">
    <Container>
      <div class="max-w-3xl mx-auto text-center mb-16">
        <div class="mb-6 inline-block">
          <Badge tone="coral" icon="ph:gift-duotone">What you walk away with</Badge>
        </div>
        <Heading level={2} visual="display-md" align="center" class="mb-4">
          A process your team will <WavyUnderline>actually use</WavyUnderline>
        </Heading>
        <Text size="lg" tone="muted" align="center">
          Not a theoretical framework. A working, repeatable handoff flow tailored to how your team already ships.
        </Text>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {deliverables.map((d) => {
          const a = deliverableAccentMap[d.accent];
          return (
            <Card variant="paper" tilt={d.tilt} padding="loose" class="relative overflow-hidden">
              <div class={`absolute -top-6 -right-6 w-24 h-24 ${a.ring} rounded-full pointer-events-none`} aria-hidden="true"></div>
              <div class="relative">
                <div class={`w-14 h-14 ${a.bg} rounded-2xl flex items-center justify-center mb-5`}>
                  <Icon name={d.icon} size={28} class={a.text} />
                </div>
                <Heading level={3} visual="h2" class="mb-2">{d.title}</Heading>
                <Text size="sm" tone="muted">{d.body}</Text>
              </div>
            </Card>
          );
        })}

        {/* Featured navy/plum card */}
        <div class="card-hover bg-gradient-to-br from-navy to-plum text-white rounded-3xl p-7 border border-navy/10 shadow-sm relative overflow-hidden rotate-1">
          <div class="absolute -top-6 -right-6 w-24 h-24 bg-coral/20 rounded-full" aria-hidden="true"></div>
          <div class="relative">
            <div class="w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center mb-5">
              <Icon name="ph:video-camera-duotone" size={28} class="text-lemon" />
            </div>
            <h3 class="font-display text-xl font-semibold mb-2">A live implementation session</h3>
            <p class="text-white/75 font-body leading-relaxed text-sm">
              A 60-minute working session with your team. We roll the new workflow out live so it lands in muscle memory, not a forgotten doc.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  {/* WHAT'S INCLUDED */}
  <Section padding="default" class="bg-charcoal/[0.03]">
    <Container width="narrow">
      <SectionHeader
        eyebrow="Inside the engagement"
        eyebrowIcon="ph:package-duotone"
        eyebrowTone="sunset"
        title="The full scope"
        lead="Six focused pieces across your process, your Figma, and your codebase."
        class="mb-14"
      />

      <Card variant="paper" padding="none" class="overflow-hidden">
        <ul class="divide-y divide-charcoal/5">
          {included.map((item) => {
            const i = includedIconMap[item.accent];
            return (
              <li class="flex items-start gap-5 p-6 md:p-7">
                <div class={`w-12 h-12 ${i.bg} rounded-xl flex items-center justify-center flex-shrink-0`}>
                  <Icon name={item.icon} size={24} class={i.text} />
                </div>
                <div>
                  <Heading level={3} visual="h4" class="mb-1 text-lg">{item.title}</Heading>
                  <Text size="sm" tone="muted">{item.body}</Text>
                </div>
              </li>
            );
          })}
        </ul>
      </Card>
    </Container>
  </Section>

  {/* PROCESS */}
  <Section padding="default">
    <Container width="narrow">
      <SectionHeader
        eyebrow="How it works"
        eyebrowIcon="ph:path-duotone"
        eyebrowTone="sage"
        title="Four steps, no hand-wavy theory"
        class="mb-14"
      />

      <div class="space-y-6">
        {process.map((step) => (
          <div class="flex gap-5">
            <div class={`w-14 h-14 rounded-full ${stepBgMap[step.tone]} text-white flex items-center justify-center font-heading font-bold text-lg flex-shrink-0 shadow-lg`}>
              {step.n}
            </div>
            <Card variant="paper" tilt={step.tilt} class="flex-1">
              <Heading level={3} visual="h3" class="mb-2">{step.title}</Heading>
              <Text tone="muted">{step.body}</Text>
            </Card>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  {/* PRICING */}
  <Section padding="tight" class="bg-charcoal/[0.03]">
    <Container width="narrow">
      <div class="relative bg-gradient-to-br from-navy via-navy to-plum rounded-3xl p-10 md:p-14 overflow-hidden">
        <Blob tone="coral" size="xl" class="absolute -top-10 -right-10" animate="float-slow" opacity="opacity-20" />
        <Blob tone="lemon" size="lg" class="absolute -bottom-8 -left-8 rounded-full" animate="float-delay" opacity="opacity-15" />
        <Blob tone="sage" size="sm" class="absolute top-8 left-1/2 rounded-full" animate="float" opacity="opacity-20" />

        <div class="relative text-center">
          <span class="inline-flex items-center gap-2 bg-white/10 text-white/90 border border-white/15 px-4 py-2 rounded-full mb-6 font-heading text-sm font-medium">
            <Icon name="ph:tag-duotone" size={18} class="text-lemon" />
            Flat-scope engagement
          </span>
          <Heading level={2} visual="h2" tone="white" align="center" class="mb-4">
            Design-to-Code Workflow
          </Heading>
          <div class="flex items-baseline justify-center gap-2 mb-6">
            <span class="text-white/60 font-heading text-lg">Starting at</span>
            <span class="font-display text-white text-5xl md:text-6xl font-semibold">$2,500</span>
          </div>
          <p class="text-white/70 font-body max-w-xl mx-auto mb-8 leading-relaxed">
            Final scope depends on team size, tooling, and how deep we go on Code Connect — we'll sort that out on the intro call. No retainers, no surprises.
          </p>
          <Button variant="primary" size="lg" iconLeft="ph:calendar-check-duotone" href="https://calendly.com/josh-thebrileys/30min/">
            Book an intro call
          </Button>
        </div>
      </div>
    </Container>
  </Section>

  {/* TESTIMONIALS */}
  <Section padding="default">
    <Container>
      <SectionHeader
        eyebrow="Kind words"
        eyebrowIcon="ph:heart-duotone"
        eyebrowTone="lemon"
        title="From folks who've worked with me"
        class="mb-14"
      />

      <TestimonialPinboard>
        <TestimonialCard
          name="Drew DiPasquale"
          role="Principal Researcher"
          company="HubSpot"
          quote="Josh sees the real problem quickly and knows how to articulate it in a way that gets teams moving. That's rare — and genuinely valuable."
          initials="DD"
          avatarTone="plum"
          variant="polaroid"
          tilt="rot-1"
          slabGradient="from-sunset/30 via-coral/20 to-plum/30"
          image="/images/drew-dipasquale.jpeg"
        />
        <TestimonialCard
          name="Michael Pertiore"
          role="Designer"
          company="Apple"
