---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/layout/Section.astro';
import Container from '~/components/layout/Container.astro';
import Heading from '~/components/primitives/Heading.astro';
import Text from '~/components/primitives/Text.astro';
import Badge from '~/components/primitives/Badge.astro';
import Button from '~/components/primitives/Button.astro';
import Icon from '~/components/primitives/Icon.astro';
import Blob from '~/components/decorative/Blob.astro';
import WavyUnderline from '~/components/decorative/WavyUnderline.astro';
import ProjectPolaroid from '~/components/patterns/ProjectPolaroid.astro';

const description =
  'Recent work by Joshua Briley: design systems, component libraries, and accessible web applications built for teams with real constraints.';
---

<BaseLayout title="Projects — Joshua Briley" description={description}>
  <!-- HERO -->
  <Section padding="loose" decorated>
    <Blob tone="lemon" size="md" class="absolute top-14 right-[8%]" animate="float" />
    <Blob tone="sage" size="sm" class="absolute top-40 left-[6%] rounded-full" animate="float-delay" opacity="opacity-40" />
    <Blob tone="sky" size="sm" class="absolute bottom-6 right-[22%]" animate="float-slow" opacity="opacity-40" />
    <Blob tone="coral" size="sm" class="absolute bottom-16 left-[12%] rounded-full" animate="float" opacity="opacity-30" />

    <Container class="relative z-10">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-7">
          <div class="mb-8 inline-block">
            <Badge tone="lemon" icon="ph:sparkle-duotone">A peek at the workbench</Badge>
          </div>
          <Heading level={1} visual="display-xl" class="mb-8">
            Recent projects pinned to the <WavyUnderline>corkboard</WavyUnderline>.
          </Heading>
          <Text size="lg" tone="muted" class="max-w-2xl">
            Component libraries, design systems, and accessible web apps built for teams with real
            constraints — messy timelines, mixed stacks, and real humans using them on the other side.
          </Text>
        </div>

        {/* Polaroid stack illustration */}
        <div class="lg:col-span-5 relative h-[380px] md:h-[460px] hidden lg:block" aria-hidden="true">
          {/* Back polaroid */}
          <div class="absolute top-[6%] right-[8%] w-56 bg-white rounded-[10px] p-3 pb-5 shadow-xl border border-charcoal/5 animate-float-slow rotate-6">
            <span class="absolute -top-3 left-[14%] w-20 h-5 bg-lemon/80 shadow-sm -rotate-6"></span>
            <div class="rounded-[6px] aspect-[4/3] flex items-center justify-center relative overflow-hidden" style="background: linear-gradient(135deg, #f3ebff 0%, #ffe8d6 100%)">
              <svg class="absolute top-3 right-3 opacity-60" width="40" height="40" viewBox="0 0 64 64" fill="none">
                <circle cx="32" cy="32" r="22" stroke="#6C4AB6" stroke-width="2" stroke-dasharray="4 4" />
                <circle cx="32" cy="32" r="10" fill="#FDE68A" opacity="0.8" />
              </svg>
              <span class="font-display italic text-2xl font-semibold text-plum">Rudiment</span>
            </div>
            <div class="mt-2 px-1 flex items-center justify-between">
              <span class="font-hand text-charcoal/60 text-sm">component lib</span>
              <span class="font-hand text-coral text-base">01</span>
            </div>
          </div>

          {/* Middle polaroid */}
          <div class="absolute top-[28%] left-[2%] w-60 bg-white rounded-[10px] p-3 pb-5 shadow-xl border border-charcoal/5 animate-float -rotate-6">
            <span class="absolute -top-2 left-1/2 -translate-x-1/2 w-[14px] h-[14px] rounded-full shadow-md" style="background: radial-gradient(circle at 35% 35%, #ff8e53, #e8573d 60%, #8a2a1a)"></span>
            <div class="rounded-[6px] aspect-[4/3] flex items-center justify-center relative overflow-hidden" style="background: linear-gradient(135deg, #ffe8d6 0%, #fde68a 100%)">
              <svg class="absolute bottom-3 left-3 opacity-60" width="40" height="40" viewBox="0 0 56 56" fill="none">
                <path d="M8 46 Q 28 8 48 46" stroke="#E8573D" stroke-width="2.5" stroke-linecap="round" fill="none" />
                <circle cx="28" cy="20" r="4" fill="#E8573D" opacity="0.7" />
              </svg>
              <span class="font-display font-semibold text-2xl text-coral">ATK</span>
            </div>
            <div class="mt-2 px-1 flex items-center justify-between">
              <span class="font-hand text-charcoal/60 text-sm">multi-brand</span>
              <span class="font-hand text-plum text-base">02</span>
            </div>
          </div>

          {/* Front polaroid */}
          <div class="absolute bottom-[4%] right-[14%] w-52 bg-white rounded-[10px] p-3 pb-5 shadow-xl border border-charcoal/5 animate-float-delay rotate-3">
            <span class="absolute -top-3 right-[12%] w-20 h-5 shadow-sm rotate-6" style="background: rgba(232, 87, 61, 0.7)"></span>
            <div class="rounded-[6px] aspect-[4/3] flex items-center justify-center relative overflow-hidden" style="background: linear-gradient(135deg, #e0f2fe 0%, #f3ebff 100%)">
              <Icon name="ph:layout-duotone" size={46} class="text-sky" />
            </div>
            <div class="mt-2 px-1 flex items-center justify-between">
              <span class="font-hand text-charcoal/60 text-sm">case study</span>
              <span class="font-hand text-sky text-base">03</span>
            </div>
          </div>

          {/* floating sticker chips */}
          <div class="absolute top-[2%] left-[8%] bg-white rounded-full shadow-lg border border-charcoal/5 px-3 py-1.5 flex items-center gap-1.5 animate-float-delay -rotate-6">
            <Icon name="ph:wheelchair-duotone" size={14} class="text-sage" />
            <span class="font-heading text-[11px] font-semibold text-navy">WCAG AA</span>
          </div>

          <div class="absolute bottom-[26%] right-[2%] bg-white rounded-full shadow-lg border border-charcoal/5 px-3 py-1.5 flex items-center gap-1.5 animate-float rotate-6">
            <Icon name="ph:package-duotone" size={14} class="text-plum" />
            <span class="font-heading text-[11px] font-semibold text-navy">Shipped</span>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <div class="squiggle-divider max-w-4xl mx-auto" aria-hidden="true"></div>

  <!-- PROJECT GRID -->
  <Section padding="default" decorated>
    <Blob tone="plum" size="lg" class="absolute top-10 right-6" animate="float-slow" opacity="opacity-20" />
    <Blob tone="sunset" size="md" class="absolute bottom-20 left-6 rounded-full" animate="float" opacity="opacity-30" />

    <Container class="relative z-10">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 lg:gap-20">
        <!-- 1. Rudiment UI -->
        <ProjectPolaroid
          href="./rudiment-ui/"
          title="Rudiment UI: Building a component library from scratch"
          summary="An open-source React component library and companion guide covering architectural decisions, a three-tier token system, intrinsic layout primitives, accessible components with React Aria, Storybook docs, testing, and npm distribution."
          cta="Read the Rudiment UI case study"
          label="Component library"
          labelTone="plum"
          labelIcon="ph:package-duotone"
          marker="01"
          tilt="-1.8deg"
          decoration="pin"
        >
          <div class="collage__bg" style="background: linear-gradient(135deg, #f3ebff 0%, #ffe8d6 100%);" aria-hidden="true"></div>
          <div class="collage__doodle" style="top: 6%; right: 6%;" aria-hidden="true">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
              <circle cx="32" cy="32" r="24" stroke="#6C4AB6" stroke-width="2" stroke-dasharray="4 4" opacity="0.5"/>
              <circle cx="32" cy="32" r="12" fill="#FDE68A" opacity="0.6"/>
            </svg>
          </div>
          <div class="collage__tape" style="top: 10px; left: 10%; transform: rotate(-6deg);" aria-hidden="true"></div>
          <div class="collage__logo">
            <span class="font-display italic text-[2.4rem] md:text-[2.8rem] leading-none font-semibold text-plum">Rudiment</span>
          </div>
          <div class="collage__sticker bg-plum/10 text-plum border-plum/40" style="top: 10%; left: 6%; transform: rotate(-3deg);">
            <Icon name="ph:package-duotone" size={12} />
            React
          </div>
          <div class="collage__sticker bg-coral/10 text-coral border-coral/40" style="bottom: 8%; right: 6%; transform: rotate(2deg);">
            <Icon name="ph:check-circle-duotone" size={12} />
            WCAG AA
          </div>
          <div class="collage__stat" style="bottom: 8%; left: 6%; transform: rotate(-3deg);">
            <div class="collage__stat-num">3-tier</div>
            <div class="collage__stat-label">Token system</div>
          </div>
        </ProjectPolaroid>

        <!-- 2. America's Test Kitchen -->
        <div class="md:mt-16">
          <ProjectPolaroid
            href="./americas-test-kitchen/"
            title="America's Test Kitchen: one library, multiple brands"
            summary="Improving an inaccessible CMS and building a shared component library for one of the most recognized cooking brands in the US."
            cta="Read the ATK case study"
            label="Multi-brand system"
            labelTone="coral"
            labelIcon="ph:chef-hat-duotone"
            marker="02"
            tilt="1.4deg"
            labelTilt="1deg"
            decoration="tape-both"
          >
            <div class="collage__bg" style="background: linear-gradient(135deg, #ffe8d6 0%, #fde68a 100%);" aria-hidden="true"></div>
            <div class="collage__doodle" style="bottom: 6%; right: 6%;" aria-hidden="true">
              <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
                <path d="M10 46 Q 28 10 46 46" stroke="#E8573D" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.55"/>
                <circle cx="28" cy="20" r="4" fill="#E8573D" opacity="0.7"/>
              </svg>
            </div>
            <div class="collage__tape" style="top: 10px; right: 10%; transform: rotate(5deg);" aria-hidden="true"></div>
            <div class="collage__logo">
              <svg viewBox="0 0 96.1 35.2" aria-hidden="true">
                <path d="M60 10.1h2.2l-1.1-2.9-1.1 2.9zM48 8.1c0-.5-.2-.9-1.1-.9h-1.4V9h1.4a.9.9 0 0 0 1.1-.7z" fill="#D73A15"></path>
                <path d="M0 0v35.2h96.1V0zm6.4 9.6h15.2v.6H6.4zm11.5 8h-2.1v11.1H14V17.6h-2.1v-1.5h6zm5.8 0h-3v3.9h2.8V23h-2.8v4.3h3v1.4H19V16.1h4.7zm3.9 11.5c-1.6 0-2.7-.7-2.7-2.3v-1.7h1.6v1c0 .8.3 1.4 1 1.4a1.2 1.2 0 0 0 1.2-1.1v-.3c0-1.1-.1-1.4-1.9-3.2s-2-2.1-2-3.8 1-2.9 2.9-2.9a3.1 3.1 0 0 1 2 .7 1.8 1.8 0 0 1 .5 1.6v1.2h-1.6v-1a.9.9 0 0 0-.7-1.1h-.3c-.7 0-1 .4-1 1.4s.2 1.4 1.8 3.1 2 2.4 2 3.9-.8 3.1-2.8 3.1zm1.9-16.7l-.6-1.6H26l-.6 1.6h-.9l2.5-6h1l2.4 6zm7.5 5.2h-2.1v11.1h-1.7V17.6h-2.1v-1.5H37zm.8-5.2H37V7l-2 5.4h-.7l-2-5.4v5.4h-.8v-6H33l1.7 5 1.7-5h1.4zm1.7-6h3.7v.7h-2.9V9h2.8v.7h-2.8v2h3v.7h-3.8zm5.6 22.3l-2.7-6.3h-.1v6.3h-1.7V16.1h1.7v5.8h.1l2.7-5.8h1.8l-3 5.9 3.2 6.7zm2.5-18.8a1.6 1.6 0 0 0-.9-.3h-1.2v2.8h-.8v-6h2.1c1 0 2 .3 2 1.5a1.2 1.2 0 0 1-1.1 1.4 1.2 1.2 0 0 1 .9 1.2 11.6 11.6 0 0 0 .4 1.8h-.9a4.3 4.3 0 0 1-.2-1.1 3.1 3.1 0 0 0-.3-1.3zm2.2 18.8H48V16.1h1.8zm.7-22.3h.9v6h-.9zm6.6 11.2H55v11.1h-1.8V17.6h-2v-1.5h5.9zm-1.8-5.8a1.2 1.2 0 0 0 1.3-1h.9a2.1 2.1 0 0 1-2.3 1.7c-1.8 0-2.5-1.4-2.5-3.1s.6-3.2 2.7-3.1a1.9 1.9 0 0 1 2.1 1.6h-.8a1.2 1.2 0 0 0-1.3-1c-1.5 0-1.8 1.4-1.8 2.4s.4 2.5 1.7 2.5zm8.1 7.8h-1.6v-.9a1.1 1.1 0 0 0-.8-1.3h-.2c-.9 0-1.1.6-1.1 2.2v6.2c0 1.5.5 1.7 1 1.7a1.2 1.2 0 0 0 1.1-1.4v-.9h1.6v1.4c0 1.3-.5 2.3-2.6 2.3s-2.9-1.2-2.9-3.1v-6.5h.1c0-1.8.6-3.3 2.9-3.3s2.5.9 2.5 2.3zm-.3-7.2l-.6-1.6h-2.8l-.6 1.6h-.9l2.5-6h.9l2.4 6zm1-4l.5-2h1l-1 2zm6.6 20.3h-1.8V23h-2.3v5.7h-1.7V16.1h1.7v5.4h2.3v-5.4h1.8zm-2.1-16.1c-1.3 0-2.2-.5-2.1-1.9h.9a1.1 1.1 0 0 0 1 1.2h.3c.7 0 1.5-.2 1.5-1a1.1 1.1 0 0 0-1-.9c-1-.2-2.6-.4-2.6-1.8s1.2-1.8 2.3-1.8a1.8 1.8 0 0 1 2 1.5H70a.9.9 0 0 0-1.1-.9h-.1a1.2 1.2 0 0 0-1.4.9c0 .7.5.7 1 .9s2.6.4 2.6 1.9-1.2 1.9-2.4 1.9zm8.1 5h-3v3.9h2.8V23h-2.8v4.3h3v1.4H72V16.1h4.7zm7.4 11.1h-2.5l-2-10.7h-.1v10.7H78V16.1h2.4l2.1 10.5V16.1h1.6zm5.6-18.5H74.5v-.6h15.2z" fill="#D73A15"></path>
                <path d="M26.3 10.1h2.2l-1.1-2.9-1.1 2.9z" fill="#D73A15"></path>
              </svg>
            </div>
            <div class="collage__sticker bg-coral/15 text-coral border-coral/40" style="top: 10%; left: 6%; transform: rotate(-2deg);">
              <Icon name="ph:chef-hat-duotone" size={12} />
              2 brands
            </div>
            <div class="collage__sticker bg-plum/10 text-plum border-plum/40" style="bottom: 8%; left: 6%; transform: rotate(3deg);">
              <Icon name="ph:wheelchair-duotone" size={12} />
              A11y rebuild
            </div>
            <div class="collage__stat" style="top: 8%; right: 6%; transform: rotate(3deg);">
              <div class="collage__stat-num">60+</div>
              <div class="collage__stat-label">Components</div>
            </div>
          </ProjectPolaroid>
        </div>

        <!-- 3. Berxi -->
        <div class="md:-mt-6">
          <ProjectPolaroid
            href="./berxi-insurance/"
            title="Berxi.com: a design system for a growing platform"
            summary="Building a custom design system for a growing insurance platform — from stakeholder alignment through component library, documentation, and cross-team adoption."
            cta="Read the Berxi case study"
            label="Design system"
            labelTone="sky"
            labelIcon="ph:shield-check-duotone"
            marker="03"
            tilt="1.2deg"
            labelTilt="-1deg"
            decoration="pin"
          >
            <div class="collage__bg" style="background: linear-gradient(135deg, #e6f4fb 0%, #c7e7f5 100%);" aria-hidden="true"></div>
            <div class="collage__doodle" style="top: 6%; left: 6%;" aria-hidden="true">
              <svg width="54" height="54" viewBox="0 0 54 54" fill="none">
                <path d="M8 42 L 20 20 L 34 32 L 48 12" stroke="#4CCAE7" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.7"/>
              </svg>
            </div>
            <div class="collage__tape" style="top: 10px; right: 12%; transform: rotate(-4deg);" aria-hidden="true"></div>
            <div class="collage__logo">
              <svg viewBox="0 0 211 57" aria-hidden="true">
                <path d="M146.241 24.5582H139.415L129.732 36.5663H128.376L118.697 24.5582H111.867L124.049 39.4523L110.572 55.634H117.159L128.368 42.2172H129.736L140.889 55.634H147.536L134.059 39.4523L146.241 24.5582Z" fill="#143A62"/>
                <path d="M156.905 24.5582H155.351C154.204 24.5582 153.272 25.4865 153.272 26.6369V55.634H158.983V26.6369C158.983 25.4906 158.051 24.5582 156.905 24.5582Z" fill="#143A62"/>
                <path d="M156.905 13.4744H155.351C154.204 13.4744 153.272 14.4028 153.272 15.5531V18.8549C153.272 20.0012 154.204 20.9336 155.351 20.9336H156.905C158.051 20.9336 158.983 20.0052 158.983 18.8549V15.5531C158.983 14.4068 158.051 13.4744 156.905 13.4744Z" fill="#143A62"/>
                <path d="M31.9477 28.1425C28.5208 25.4744 23.8427 23.9447 19.1202 23.9447C14.3976 23.9447 9.21498 25.7408 5.71143 28.5784V15.5491C5.71143 14.4027 4.77903 13.4703 3.63271 13.4703H2.07872C0.932396 13.4703 0 14.3987 0 15.5491V55.63H5.71143V51.6178C9.21498 54.4514 14.3654 56.2516 19.1202 56.2516C23.875 56.2516 28.5975 54.7218 31.9436 52.0578C33.9134 50.5644 34.874 48.4453 34.874 45.5835V34.6773C34.874 31.8034 33.9457 29.7287 31.9477 28.1465V28.1425ZM28.9204 45.2122C28.9204 47.2303 28.2988 48.1345 26.1474 49.2404C23.4875 50.6854 21.6833 51.3313 18.0223 51.3313C14.0102 51.3313 8.03233 49.2324 5.4087 46.0961V34.092C8.00407 30.9921 13.9859 28.9215 18.0223 28.9215C21.6792 28.9215 23.4835 29.5673 26.1555 31.0163C28.3271 32.1304 28.9204 32.9941 28.9204 35.0406V45.2122Z" fill="#143A62"/>
                <path d="M73.5988 28.1385C69.8167 25.3171 65.0619 23.9487 59.0639 23.9487C53.0659 23.9487 48.0971 25.3372 44.4685 28.0779C42.4705 29.5794 41.5381 31.6178 41.5381 34.4917V45.7652C41.5381 48.7238 42.4987 50.8833 44.4685 52.3646C47.9962 55.0084 53.0457 56.187 60.8439 56.187C64.3031 56.187 67.7098 55.9771 70.8823 55.5735V50.6572C66.8541 51.2506 63.3424 51.3919 60.9045 51.3919C55.4837 51.3919 52.8237 50.9115 49.9539 49.4181C47.6693 48.2475 47.2495 47.1416 47.2495 45.3938V42.0921H72.9126C75.5201 42.0921 76.5332 41.0749 76.5332 38.4715V34.6128C76.5332 31.7268 75.6048 29.6723 73.6028 28.1385H73.5988ZM70.8823 37.4261H47.2495V34.7379C47.2495 32.9901 47.6693 31.8882 49.9539 30.7136C52.9973 29.1274 55.7985 28.8004 59.0639 28.8004C62.7612 28.8004 65.3001 29.3695 68.1174 30.8347C70.2607 31.9367 70.8823 32.8368 70.8823 34.859V37.4261Z" fill="#143A62"/>
                <path d="M107.367 27.4644L106.987 26.084C106.681 24.978 105.538 24.3282 104.432 24.6309L88.9087 28.9175V26.6329C88.9087 25.4866 87.9763 24.5542 86.83 24.5542H85.276C84.1297 24.5542 83.1973 25.4826 83.1973 26.6329V55.63H88.9087V34.084L105.922 30.0194C107.028 29.7126 107.678 28.5663 107.371 27.4604L107.367 27.4644Z" fill="#143A62"/>
                <path d="M190.705 41.1194C201.914 41.1194 211 32.0331 211 20.8247C211 9.61617 201.914 0.529907 190.705 0.529907C179.497 0.529907 170.411 9.61617 170.411 20.8247C170.411 32.0331 179.497 41.1194 190.705 41.1194Z" fill="#4CCAE7"/>
                <path d="M190.705 32.8853L196.542 35.194L201.773 20.8247L196.542 6.45526L190.705 8.76405L184.865 6.45526L179.634 20.8247L184.865 35.194L190.705 32.8853Z" fill="#143A62"/>
              </svg>
            </div>
            <div class="collage__sticker bg-sky/20 text-sky border-sky/50" style="top: 10%; right: 6%; transform: rotate(3deg);">
              <Icon name="ph:shield-check-duotone" size={12} />
              Insurance
            </div>
            <div class="collage__sticker bg-plum/10 text-plum border-plum/40" style="bottom: 8%; right: 6%; transform: rotate(-2deg);">
              <Icon name="ph:users-three-duotone" size={12} />
              Cross-team
            </div>
            <div class="collage__stat" style="bottom: 8%; left: 6%; transform: rotate(-3deg);">
              <div class="collage__stat-num">v2.0</div>
              <div class="collage__stat-label">Platform</div>
            </div>
          </ProjectPolaroid>
        </div>

        <!-- 4. IVFCRYO -->
        <div class="md:mt-10">
          <ProjectPolaroid
            href="./ivfcryo/"
            title="IVFCRYO: accessibility built in from the start"
            summary="A self-service shipping application for a fertility specimen logistics provider, with real-time environmental tracking, multi-carrier label printing, and accessibility built in from day one."
            cta="Read the IVFCRYO case study"
            label="Accessibility first"
            labelTone="sage"
            labelIcon="ph:heart-duotone"
            marker="04"
            tilt="-1.1deg"
            labelTilt="1.5deg"
            decoration="tape-l"
          >
            <div class="collage__bg" style="background: linear-gradient(135deg, #fff4e6 0%, #ffd9b3 100%);" aria-hidden="true"></div>
            <div class="collage__doodle" style="bottom: 6%; left: 6%;" aria-hidden="true">
              <svg width="60" height="60" viewBox="0 0 60 60" fill="none">
                <rect x="12" y="18" width="36" height="28" rx="3" stroke="#003A70" stroke-width="2" fill="none" opacity="0.6"/>
                <path d="M18 28 L 30 28 M 18 34 L 42 34 M 18 40 L 36 40" stroke="#003A70" stroke-width="2" stroke-linecap="round" opacity="0.4"/>
              </svg>
            </div>
            <div class="collage__tape" style="top: 10px; right: 14%; transform: rotate(4deg);" aria-hidden="true"></div>
            <div class="collage__logo">
              <svg viewBox="0 0 536.5 87.4" aria-hidden="true">
                <path fill="#FF8204" d="M0,2h14.8v84H0V2z"/>
