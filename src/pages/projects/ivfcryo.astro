---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Button from '~/components/primitives/Button.astro';
import Icon from '~/components/primitives/Icon.astro';
import Blob from '~/components/decorative/Blob.astro';
import SquiggleDivider from '~/components/decorative/SquiggleDivider.astro';

const title = 'IVFCRYO — Joshua Briley';
const description: string =
  'Case study: building a self-service fertility logistics app with accessibility wired into the architecture from day one.';
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <style>
      .tape {
        position: absolute;
        width: 90px;
        height: 22px;
        background: rgba(253, 230, 138, 0.88);
        box-shadow: 0 2px 6px -2px rgba(0, 0, 0, 0.15);
        z-index: 5;
      }
    </style>
  </Fragment>

  <div class="corkboard">
    <!-- ====== HERO — recipe card ====== -->
    <section class="relative overflow-hidden pt-16 pb-20 md:pt-24 md:pb-28">
      <Blob tone="sky" size="lg" class="absolute top-14 right-[6%]" animate="float" opacity="opacity-70" />
      <div
        class="absolute top-40 left-[4%] w-12 h-12 bg-plum/30 rounded-full animate-float-delay"
        aria-hidden="true"
      ></div>
      <Blob tone="lemon" size="md" class="absolute bottom-20 right-[18%] w-14 h-14" animate="float-slow" opacity="opacity-60" />
      <div
        class="absolute bottom-24 left-[10%] w-9 h-9 bg-coral/20 rounded-full animate-float"
        aria-hidden="true"
      ></div>

      <div class="max-w-4xl mx-auto px-6 relative z-10">
        <nav
          class="mb-10 flex items-center justify-center gap-2 font-heading text-sm text-charcoal/60"
          aria-label="Breadcrumb"
        >
          <a href="/projects/" class="hover:text-coral transition-colors">Projects</a>
          <Icon name="ph:caret-right-bold" size={12} />
          <span class="text-navy">IVFCRYO</span>
        </nav>

        <article
          class="recipe-card p-8 md:p-14"
          style="transform: rotate(-0.4deg)"
        >
          <span
            class="tape"
            style="top: -14px; left: 10%; transform: rotate(-6deg)"
            aria-hidden="true"
          ></span>
          <span
            class="tape"
            style="top: -14px; right: 10%; transform: rotate(5deg)"
            aria-hidden="true"
          ></span>

          <div
            class="absolute -top-10 left-1/2 -translate-x-1/2 flex gap-3"
            aria-hidden="true"
          >
            <span class="steam animate-steam"></span>
            <span class="steam animate-steam-delay"></span>
            <span class="steam animate-steam-delay-2"></span>
          </div>

          <div class="relative text-center">
            <div class="project-logo-tag">
              <img src="/images/logos/ivfcryo.svg" alt="IVFCRYO logo" />
            </div>

            <div
              class="inline-flex items-center gap-2 bg-plum/10 text-plum px-4 py-2 rounded-full mb-6 font-heading text-xs font-semibold border border-plum/20 uppercase tracking-wider"
            >
              <Icon name="ph:snowflake-duotone" size={18} />
              Case study &middot; Recipe no. 03
            </div>

            <p class="marker-label text-2xl md:text-3xl mb-4">
              from the lab notebook —
            </p>

            <h1
              class="font-display text-4xl sm:text-5xl md:text-6xl font-semibold text-navy leading-[1.05] tracking-tight mb-6"
            >
              What it looks like when
              <br />
              <span class="relative inline-block">
                accessibility
                <svg
                  class="absolute -bottom-3 left-0 w-full"
                  viewBox="0 0 260 14"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M3 9 Q 65 2 130 9 Q 195 16 257 7"
                    stroke="#6C4AB6"
                    stroke-width="3"
                    stroke-linecap="round"
                    opacity="0.55"
                  />
                </svg>
              </span>
              is built in from the start.
            </h1>

            <p
              class="text-lg md:text-xl text-charcoal/70 max-w-2xl mx-auto font-body leading-relaxed mb-10"
            >
              A self-service shipping application for
              <span class="wavy-underline">fertility specimen logistics</span>,
              with real-time environmental tracking, multi-carrier labels,
              and a legally blind collaborator in the room from day one.
            </p>

            <div class="border-t border-dashed border-plum/25 pt-6 mt-2">
              <dl
                class="grid grid-cols-2 md:grid-cols-4 gap-6 text-left md:text-center"
              >
                <div>
                  <dt
                    class="font-heading text-[0.7rem] uppercase tracking-widest text-plum/70 mb-1"
                  >
                    Role
                  </dt>
                  <dd class="font-display text-lg text-navy font-semibold">
                    UX Engineer
                  </dd>
                </div>
                <div>
                  <dt
                    class="font-heading text-[0.7rem] uppercase tracking-widest text-plum/70 mb-1"
                  >
                    Domain
                  </dt>
                  <dd class="font-display text-lg text-navy font-semibold">
                    Fertility logistics
                  </dd>
                </div>
                <div>
                  <dt
                    class="font-heading text-[0.7rem] uppercase tracking-widest text-plum/70 mb-1"
                  >
                    Stack
                  </dt>
                  <dd class="font-display text-lg text-navy font-semibold">
                    Web &middot; Sensors
                  </dd>
                </div>
                <div>
                  <dt
                    class="font-heading text-[0.7rem] uppercase tracking-widest text-plum/70 mb-1"
                  >
                    Focus
                  </dt>
                  <dd class="font-display text-lg text-navy font-semibold">
                    A11y-first arch.
                  </dd>
                </div>
              </dl>
            </div>
          </div>
        </article>
      </div>
    </section>

    <SquiggleDivider />

    <!-- ====== INGREDIENTS (outline) ====== -->
    <section class="py-16 md:py-20 relative">
      <Blob tone="plum" size="lg" class="absolute top-10 right-6" animate="float-slow" opacity="opacity-20" />

      <div class="max-w-4xl mx-auto px-6 relative z-10">
        <div class="flex items-center gap-3 mb-6">
          <Icon name="ph:list-checks-duotone" size={28} class="text-sunset" />
          <h2
            class="font-display text-2xl md:text-3xl text-navy font-semibold"
          >
            On the bench
          </h2>
        </div>
        <div class="flex flex-wrap gap-3">
          <a
            href="#stakes"
            class="ingredient-chip hover:border-coral hover:text-coral transition-colors"
          >
            <Icon name="ph:warning-circle-duotone" size={18} class="text-coral" />
            The stakes behind the product
          </a>
          <a
            href="#collaborator"
            class="ingredient-chip hover:border-coral hover:text-coral transition-colors"
          >
            <Icon name="ph:users-three-duotone" size={18} class="text-plum" />
            A blind user in the room
          </a>
          <a
            href="#architecture"
            class="ingredient-chip hover:border-coral hover:text-coral transition-colors"
          >
            <Icon name="ph:stack-duotone" size={18} class="text-sunset" />
            Accessibility in the architecture
          </a>
          <a
            href="#scale"
            class="ingredient-chip hover:border-coral hover:text-coral transition-colors"
          >
            <Icon name="ph:trend-up-duotone" size={18} class="text-sage" />
            Why this compounds at scale
          </a>
        </div>

        <p
          class="mt-10 text-lg md:text-xl text-charcoal/80 leading-relaxed font-body"
        >
          IVFCRYO replaced a manual, paper-based shipping process with a web
          application that handles shipment requests, label generation across
          multiple carriers, and real-time specimen tracking from integrated
          sensor data. The people using it are usually in the middle of
          something high-stakes and emotionally sensitive. Clarity and
          reliability aren't nice-to-haves here. They're features of the
          product, and accessibility is how that clarity reaches everyone.
        </p>
      </div>
    </section>

    <!-- ====== STEP 01 — STAKES ====== -->
    <section id="stakes" class="py-16 md:py-20 relative scroll-mt-24">
      <div class="max-w-4xl mx-auto px-6">
        <div class="flex items-start gap-6 mb-8">
          <span class="step-num" aria-hidden="true">01</span>
          <div>
            <p
              class="font-heading text-xs uppercase tracking-widest text-plum/70 mb-1"
            >
              Step one
            </p>
            <h2
              class="font-display text-3xl md:text-4xl text-navy font-semibold leading-tight"
            >
              The stakes behind the product
            </h2>
          </div>
        </div>

        <div
          class="space-y-5 text-charcoal/80 text-lg leading-relaxed font-body"
        >
          <p>
            Fertility logistics has a narrow margin for error. A mislabeled
            shipment, a missed temperature excursion, or an ambiguous status
            update isn't just a workflow annoyance. It can have irreversible
            consequences for someone's family. The people using this tool are
            often clinicians working under time pressure, or patients and
            couriers navigating a process they've never touched before, during
            one of the most stressful weeks of their lives.
          </p>
          <p>
            That reframes what accessibility means here. It isn't a compliance
            checkbox to satisfy at the end of the build. It's part of how the
            product communicates <em>at all</em>: whether status updates
            reach the person who needs to act on them, whether form errors are
            recoverable, whether a screen reader user can trust what the page
            is telling them.
          </p>
        </div>

        <!-- stakes pair -->
        <div class="mt-10 grid md:grid-cols-2 gap-6">
          <div
            class="bg-white rounded-2xl p-6 border border-coral/20 shadow-sm relative"
            style="transform: rotate(-0.6deg)"
          >
            <span
              class="sticker bg-coral/10 text-coral border-coral/40 absolute -top-3 left-5"
            >
              High-stakes input
            </span>
            <h3
              class="font-display text-xl text-navy font-semibold mt-4 mb-2"
            >
              Specimens &amp; sensors
            </h3>
            <p class="text-charcoal/70">
              Temperature data, chain-of-custody details, carrier handoffs,
              all flowing through forms people may be filling out under
              duress.
            </p>
          </div>
          <div
            class="bg-white rounded-2xl p-6 border border-plum/20 shadow-sm relative"
            style="transform: rotate(0.5deg)"
          >
            <span
              class="sticker bg-plum/10 text-plum border-plum/40 absolute -top-3 left-5"
            >
              High-stakes output
            </span>
            <h3
              class="font-display text-xl text-navy font-semibold mt-4 mb-2"
            >
              Status &amp; recovery
            </h3>
            <p class="text-charcoal/70">
              A shipment that has moved, a label that has printed, an error
              that needs correcting. The app has to surface all of it,
              reliably, to every user.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== STEP 02 — COLLABORATOR ====== -->
    <section id="collaborator" class="py-16 md:py-20 relative scroll-mt-24">
      <div
        class="absolute bottom-20 left-6 w-16 h-16 bg-sunset/20 rounded-full animate-float"
        aria-hidden="true"
      ></div>
      <div class="max-w-4xl mx-auto px-6 relative z-10">
        <div class="flex items-start gap-6 mb-8">
          <span class="step-num" aria-hidden="true">02</span>
          <div>
            <p
              class="font-heading text-xs uppercase tracking-widest text-plum/70 mb-1"
            >
              Step two
            </p>
            <h2
              class="font-display text-3xl md:text-4xl text-navy font-semibold leading-tight"
            >
              A blind user in the room, from day one
            </h2>
          </div>
        </div>

        <div
          class="space-y-5 text-charcoal/80 text-lg leading-relaxed font-body"
        >
          <p>
            The most consequential decision on this project wasn't technical.
            Instead of treating accessibility as an end-of-project audit, the
            team brought in a legally blind customer as an ongoing
            collaborator. He reviewed interface decisions as they were being
            made, tested with a screen reader while components were still
            being built, and kept offering feedback as features shipped.
          </p>
          <p>
            That changes what you build, not just what you fix. Problems that
            would have surfaced as a long list of bugs at the end (the kind
            that usually get triaged, downgraded, and half-addressed) instead
            showed up as design conversations while the design was still cheap
            to change. The output wasn't a remediation report. It was
            different decisions.
          </p>
        </div>

        <ul class="mt-8 space-y-5">
          <li
            class="flex gap-4 bg-white rounded-2xl p-5 border border-charcoal/5 shadow-sm"
          >
            <Icon name="ph:megaphone-duotone" size={28} class="text-plum flex-shrink-0 mt-1" />
            <div>
              <h3 class="font-display text-lg text-navy font-semibold mb-1">
                Real-time form validation
              </h3>
              <p class="text-charcoal/70">
                Errors announced to a screen reader the moment they happen,
                not buried in a summary at the top of the page after submit.
              </p>
            </div>
          </li>
          <li
            class="flex gap-4 bg-white rounded-2xl p-5 border border-charcoal/5 shadow-sm"
          >
            <Icon name="ph:broadcast-duotone" size={28} class="text-coral flex-shrink-0 mt-1" />
            <div>
              <h3 class="font-display text-lg text-navy font-semibold mb-1">
                Status updates that reach you
              </h3>
              <p class="text-charcoal/70">
                Shipment state changes are announced automatically, so a user
                doesn't have to go hunting through the page to learn that
                something moved.
              </p>
            </div>
          </li>
          <li
            class="flex gap-4 bg-white rounded-2xl p-5 border border-charcoal/5 shadow-sm"
          >
            <Icon name="ph:compass-duotone" size={28} class="text-sunset flex-shrink-0 mt-1" />
            <div>
              <h3 class="font-display text-lg text-navy font-semibold mb-1">
                Navigation you can learn once
              </h3>
              <p class="text-charcoal/70">
                Consistent, predictable patterns across the app. The kind of
                thing a sighted user takes for granted and a screen reader
                user notices immediately when it's missing.
              </p>
            </div>
          </li>
        </ul>

        <!-- pull quote -->
        <figure
          class="mt-12 bg-plum/5 border-l-4 border-coral rounded-r-2xl p-6 md:p-8 relative"
          style="transform: rotate(-0.3deg)"
        >
          <Icon name="ph:quotes-duotone" size={32} class="text-coral/60 absolute -top-3 left-6 bg-cream px-1" />
          <blockquote
            class="pull-quote text-xl md:text-2xl text-navy leading-snug"
          >
            Accessible output at scale comes from accessible architecture,
            not from accessible intent.
          </blockquote>
        </figure>
      </div>
    </section>

    <!-- ====== STEP 03 — ARCHITECTURE ====== -->
    <section id="architecture" class="py-16 md:py-20 relative scroll-mt-24">
      <div class="max-w-4xl mx-auto px-6">
        <div class="flex items-start gap-6 mb-8">
          <span class="step-num" aria-hidden="true">03</span>
          <div>
            <p
              class="font-heading text-xs uppercase tracking-widest text-plum/70 mb-1"
            >
              Step three
            </p>
            <h2
              class="font-display text-3xl md:text-4xl text-navy font-semibold leading-tight"
            >
              Accessibility in the architecture
            </h2>
          </div>
        </div>

        <div
          class="space-y-5 text-charcoal/80 text-lg leading-relaxed font-body"
        >
          <p>
            Collaboration gave us the right instincts. Architecture made those
            instincts load-bearing. Interactive components were built with
            keyboard operability and ARIA as
            <strong class="text-coral">primary requirements</strong>, not
            post-hoc additions. Components that controlled visibility managed
            their own focus internally, so the user never lost their place.
            Dynamic content (the part of the app that changes while you're
            looking at it) announced itself to assistive tech instead of
            silently updating the DOM.
          </p>
          <p>
            Every piece of information in the UI was expressed through more
            than one channel: text <em>and</em> icon <em>and</em> color, never
            color alone. That rule is small, almost boring, and it prevents an
            enormous class of failures that would otherwise quietly ship.
          </p>
        </div>

        <!-- a11y checklist -->
        <div
          class="mt-10 bg-white rounded-3xl p-7 md:p-9 border border-charcoal/5 shadow-sm relative"
          style="transform: rotate(0.4deg)"
        >
          <div
            class="absolute -top-4 left-8 sticker bg-sage/20 text-sage border-sage/50"
            style="transform: rotate(-3deg)"
          >
            <Icon name="ph:check-fat-duotone" size={14} class="mr-1" />
            Built-in, not bolted-on
          </div>
          <ul
            class="grid sm:grid-cols-2 gap-x-8 gap-y-3 mt-4 font-body text-charcoal/80"
          >
            <li class="flex items-center gap-3">
              <Icon name="ph:keyboard-duotone" size={22} class="text-plum" />
              Full keyboard operability
            </li>
            <li class="flex items-center gap-3">
              <Icon name="ph:target-duotone" size={22} class="text-coral" />
              Internal focus management
            </li>
            <li class="flex items-center gap-3">
              <Icon name="ph:megaphone-duotone" size={22} class="text-sunset" />
              Live regions for dynamic updates
            </li>
            <li class="flex items-center gap-3">
              <Icon name="ph:eye-duotone" size={22} class="text-sky" />
              Multi-channel information design
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ====== STEP 04 — SCALE ====== -->
    <section id="scale" class="py-16 md:py-20 relative scroll-mt-24">
      <Blob tone="lemon" size="lg" class="absolute top-10 right-6 w-20 h-20" animate="float-slow" opacity="opacity-50" />
      <div class="max-w-4xl mx-auto px-6 relative z-10">
        <div class="flex items-start gap-6 mb-8">
          <span class="step-num" aria-hidden="true">04</span>
          <div>
            <p
              class="font-heading text-xs uppercase tracking-widest text-plum/70 mb-1"
            >
              Step four
            </p>
            <h2
              class="font-display text-3xl md:text-4xl text-navy font-semibold leading-tight"
            >
              Why this compounds at scale
            </h2>
          </div>
        </div>

        <div
          class="space-y-5 text-charcoal/80 text-lg leading-relaxed font-body"
        >
          <p>
            Once the component library has the right behaviors baked in, every
            feature built on top of it inherits them. A developer shipping a
            new shipment form doesn't have to remember to wire up live
            regions, or decide how focus should move when a dialog opens, or
            check contrast against the palette. Those decisions have already
            been made, correctly, once.
          </p>
          <p>
            That's the structural benefit of putting accessibility at the
            architectural level: it stops being a discipline individual
            developers have to sustain, and starts being a property of the
            system they're building inside. The ceiling of accessibility in
            the product is no longer the ceiling of any one engineer's
            attention.
          </p>
        </div>

        <!-- outcomes grid -->
        <div class="mt-12 grid md:grid-cols-3 gap-6">
          <div
            class="bg-white rounded-2xl p-6 border border-charcoal/5 shadow-sm"
            style="transform: rotate(-0.6deg)"
          >
            <Icon name="ph:shield-check-duotone" size={32} class="text-coral mb-3" />
            <h3 class="font-display text-lg text-navy font-semibold mb-1">
              Inherited by default
            </h3>
            <p class="text-charcoal/70 text-sm">
              New features get accessible behavior without anyone having to
              remember to add it.
            </p>
          </div>
          <div
            class="bg-white rounded-2xl p-6 border border-charcoal/5 shadow-sm"
            style="transform: rotate(0.4deg)"
          >
            <Icon name="ph:chat-circle-dots-duotone" size={32} class="text-plum mb-3" />
            <h3 class="font-display text-lg text-navy font-semibold mb-1">
              Clarity for every user
            </h3>
            <p class="text-charcoal/70 text-sm">
              Status changes, errors, and recovery paths reach the person who
              needs to act on them.
            </p>
          </div>
          <div
            class="bg-white rounded-2xl p-6 border border-charcoal/5 shadow-sm"
            style="transform: rotate(-0.3deg)"
          >
            <Icon name="ph:infinity-duotone" size={32} class="text-sunset mb-3" />
            <h3 class="font-display text-lg text-navy font-semibold mb-1">
              Costs that don't snowball
            </h3>
            <p class="text-charcoal/70 text-sm">
              No remediation backlog waiting at the end of the project,
              because the backlog was never created.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== PRAISE FROM THE HIRING MANAGER ====== -->
    <section class="py-16 md:py-20 relative">
      <Blob tone="sky" size="lg" class="absolute top-12 left-6 w-20 h-20" animate="float-slow" opacity="opacity-30" />
      <div
        class="absolute bottom-10 right-8 w-14 h-14 bg-plum/25 rounded-full animate-float"
        aria-hidden="true"
      ></div>

      <div class="max-w-4xl mx-auto px-6 relative z-10">
        <div class="text-center mb-10">
          <p class="marker-label text-2xl md:text-3xl text-coral mb-1">
            signed off &mdash;
          </p>
          <h2
            class="font-display text-2xl md:text-3xl text-navy font-semibold"
          >
            What Don said
          </h2>
        </div>

        <figure class="card-base card-sticky rot-1 max-w-2xl mx-auto p-8 md:p-12">
          <span class="pin plum" aria-hidden="true"></span>

          <Icon name="ph:quotes-duotone" size={36} class="text-plum/60 mb-3" />

          <blockquote
            class="font-hand text-2xl md:text-3xl text-navy leading-snug mb-7"
          >
            What Josh did at IVFCRYO wasn't a typical build. He insisted we
            put a blind user in the room from week one, and that decision
            changed the product. We didn't pass an accessibility audit at
            the end &mdash; we shipped a tool that was accessible because
            it was built that way.
          </blockquote>

          <figcaption
            class="flex items-center gap-4 pt-5 border-t border-navy/15"
          >
            <img
              src="/images/don-fish.png"
              alt="Don Fish"
              class="avatar avatar-lg"
              loading="lazy"
              decoding="async"
            />
            <div>
              <p class="font-heading font-semibold text-navy text-base">
                Don Fish
              </p>
              <p class="text-sm text-navy/70">
                CEO &middot; IVFCRYO
              </p>
            </div>
          </figcaption>
        </figure>
      </div>
    </section>

    <SquiggleDivider />

    <!-- ====== CTA ====== -->
    <section class="py-20 md:py-28">
      <div class="max-w-4xl mx-auto px-6">
        <div
          class="bg-navy text-white rounded-[2rem] p-10 md:p-14 relative overflow-hidden"
        >
          <Blob tone="coral" size="xl" class="absolute -top-10 -right-10 w-40 h-40" animate="float-slow" opacity="opacity-30" />
          <div
            class="absolute -bottom-8 -left-8 w-28 h-28 bg-plum/40 rounded-full animate-float"
            aria-hidden="true"
          ></div>
          <div class="relative z-10 text-center">
            <span
              class="sticker bg-white/10 text-lemon border-lemon/40 mb-6"
              style="transform: rotate(-2deg)"
            >
              <Icon name="ph:magnifying-glass-duotone" size={14} class="mr-1" />
              Component library leaking accessibility?
            </span>
            <h2
              class="font-display text-3xl md:text-4xl lg:text-5xl font-semibold leading-tight mb-5"
            >
              Let's audit your design system.
            </h2>
            <p class="text-white/70 text-lg max-w-xl mx-auto mb-8 font-body">
              Start with a free scorecard, or grab 30 minutes on my calendar
              to talk through where accessibility is slipping out of your
              architecture.
            </p>
            <div
