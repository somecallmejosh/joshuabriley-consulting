---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Button from '~/components/primitives/Button.astro';
import Icon from '~/components/primitives/Icon.astro';
import Blob from '~/components/decorative/Blob.astro';
import WavyUnderline from '~/components/decorative/WavyUnderline.astro';

const title = 'VMSpark — Joshua Briley';
const description =
  'Case study: redesigning the VMSpark admin shell — a multi-tenant VMS-to-ATS pipeline — to read as a 2026-caliber product without touching the pipeline underneath. Covers inventory, direction selection, phased rollout, and brand alignment.';

interface Finding {
  count: string;
  title: string;
  body: string; // raw HTML
}

const findings: Finding[] = [
  {
    count: '8+',
    title: 'Button styles competing for attention',
    body:
      'Primary, secondary, danger, and ghost variants — each implemented two or three different ways. Some leaned on Bootstrap utility classes, others on per-view custom CSS, a few were inline-styled anchors pretending to be buttons. A <em>Save</em> on one screen didn’t match a <em>Save</em> two clicks away.',
  },
  {
    count: '10+',
    title: 'Form element styles, all at once',
    body:
      'Plain Rails helpers sat next to Bootstrap <code class="text-plum">form-control</code> inputs, Select2 widgets, and hand-rolled dropdowns. Border radius, padding, focus rings, and disabled treatments all diverged. The same concept — <em>pick one from a list</em> — rendered five different ways across the app.',
  },
  {
    count: '5',
    title: 'Form-rendering patterns, coexisting',
    body:
      '<code class="text-plum">form_with(model:)</code>, legacy <code class="text-plum">form_for</code>, <code class="text-plum">form_with(url:)</code>, bare <code class="text-plum">&lt;form&gt;</code> + HTMX, and HTMX-only with <code class="text-plum">hx-include</code>.',
  },
  {
    count: '6+',
    title: 'Tables with no shared convention',
    body:
      'Row striping in some, not in others. Headers styled four ways: dark fill, light fill, borderless, and all-caps. Pagination rendered with Kaminari on one screen and a bespoke HTMX block on the next. Density jumped from compressed to roomy between adjacent views with no underlying logic.',
  },
  {
    count: '4+',
    title: 'Labeling strategies, all coexisting',
    body:
      'Sentence case, Title Case, ALL CAPS, and placeholder-as-label all appeared across the app. Required indicators were sometimes asterisks, sometimes parenthetical <em>(required)</em>, sometimes absent. The same field concept carried different names on different screens (<em>Bill Rate</em>, <em>Rate</em>, <em>Pay Rate</em>).',
  },
  {
    count: '~40',
    title: 'Views bypassing the token system',
    body:
      'A semantic color-token system already existed in <code class="text-plum">_color_tokens.scss</code>, but dozens of views bypassed it with inline styles, hardcoded hex literals, and raw colors in view-level <code class="text-plum">&lt;style&gt;</code> blocks.',
  },
  {
    count: '☠',
    title: 'Dead code in production',
    body:
      'A zero-byte <code class="text-plum">_empty.html.erb</code>, an <code class="text-plum">X</code>-prefixed dead index file (101 lines), an <code class="text-plum">ASDKAJSHDJHASD</code> debug string committed to production, and a sticky table header with hardcoded <code class="text-plum">background-color: red</code> from an abandoned debug session.',
  },
];

interface SprawlImg {
  src: string;
  alt: string;
  rotate: string;
  tape: string;
  caption: string; // raw HTML
}

const sprawlImages: SprawlImg[] = [
  {
    src: '/images/projects/vmspark/before-manual-jobs.png',
    alt: 'VMSpark Manual Jobs screen. Three buttons sit side by side in the top bar: a filled orange Add New, an outlined Edit Selected, and an outlined Copy Selected. Search inputs appear above the table with labels placed below each field.',
    rotate: '-0.6deg',
    tape: 'top: -14px; left: 18%; transform: rotate(-4deg)',
    caption:
      '<strong class="text-navy font-semibold">Manual Jobs.</strong> Three buttons in one row, three different treatments. Labels sit below inputs.',
  },
  {
    src: '/images/projects/vmspark/before-ats-professions.png',
    alt: 'VMSpark ATS Professions screen. Five search inputs use their label text as placeholders inside the fields. A Sync with ATS outlined button sits at the top right.',
    rotate: '0.4deg',
    tape: 'top: -14px; right: 15%; transform: rotate(5deg)',
    caption:
      '<strong class="text-navy font-semibold">ATS Professions.</strong> Labels are now placeholders inside the inputs. Different page, different rule.',
  },
  {
    src: '/images/projects/vmspark/before-announcements.png',
    alt: 'VMSpark Announcements screen. Each row ends with a dark gray pencil edit icon next to a solid red trash icon. A filled orange New Announcement button sits in the top right.',
    rotate: '-0.3deg',
    tape: 'top: -14px; left: 22%; transform: rotate(-3deg)',
    caption:
      '<strong class="text-navy font-semibold">Announcements.</strong> Yet another icon-button pattern — dark gray paired with solid red, nothing like the blue outlines elsewhere.',
  },
  {
    src: '/images/projects/vmspark/before-openai-usage.png',
    alt: 'VMSpark OpenAI Usage dashboard. A data table with a solid dark-navy header bar, right-aligned numeric columns, and underlined orange account names.',
    rotate: '0.6deg',
    tape: 'top: -14px; right: 20%; transform: rotate(4deg)',
    caption:
      '<strong class="text-navy font-semibold">OpenAI Usage.</strong> A solid dark-navy table header. Every other table in the app uses a light gray one.',
  },
];

const outcomeStats = [
  {
    icon: 'ph:shield-check-duotone',
    iconClass: 'text-sage',
    title: 'Zero pipeline regressions',
    body: 'No regressions reported against the ingest or fan-out paths after cutover.',
    rotate: '-0.6deg',
  },
  {
    icon: 'ph:users-duotone',
    iconClass: 'text-sunset',
    title: 'Consumer confidence',
    body: 'Operators use a tool that looks like one product, not ten. The UI stopped fighting them at every screen.',
    rotate: '0.4deg',
  },
  {
    icon: 'ph:presentation-chart-duotone',
    iconClass: 'text-plum',
    title: 'Investor confidence',
    body: 'Demos open with the product, not with caveats about the surface it lives on.',
    rotate: '-0.3deg',
  },
  {
    icon: 'ph:gauge-duotone',
    iconClass: 'text-coral',
    title: 'No new JS on hot paths',
    body: 'Palette and inspector load on demand. First paint got lighter, not heavier.',
    rotate: '0.3deg',
  },
];
---

<BaseLayout title={title} description={description}>
  <!-- ====== HERO ====== -->
  <section class="relative overflow-hidden pt-16 pb-20 md:pt-24 md:pb-28">
    <div
      class="absolute top-14 right-[6%] w-20 h-20 bg-coral/30 blob-shape animate-float opacity-70"
      aria-hidden="true"
    ></div>
    <div
      class="absolute top-40 left-[4%] w-12 h-12 bg-plum/20 rounded-full animate-float-delay"
      aria-hidden="true"
    ></div>
    <div
      class="absolute bottom-20 right-[18%] w-14 h-14 bg-lemon/60 blob-shape animate-float-slow"
      aria-hidden="true"
    ></div>
    <div
      class="absolute bottom-24 left-[10%] w-9 h-9 bg-sunset/20 rounded-full animate-float"
      aria-hidden="true"
    ></div>

    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <nav
        class="mb-10 flex items-center justify-center gap-2 font-heading text-sm text-charcoal/60"
        aria-label="Breadcrumb"
      >
        <a href="/projects/" class="hover:text-coral transition-colors">Projects</a>
        <Icon name="ph:caret-right-bold" size={12} />
        <span class="text-navy">VMSpark</span>
      </nav>

      <article class="shell-card p-8 md:p-14" style="transform: rotate(-0.4deg)">
        <span
          class="tape"
          style="top: -14px; left: 10%; transform: rotate(-6deg)"
          aria-hidden="true"
        ></span>
        <span
          class="tape"
          style="top: -14px; right: 10%; transform: rotate(5deg)"
          aria-hidden="true"
        ></span>

        <div
          class="absolute top-8 right-8 hidden md:block text-coral paper-stamp"
          aria-hidden="true"
        >
          Shipped&nbsp;·&nbsp;In&nbsp;production
        </div>

        <div class="relative text-center">
          <div class="project-logo-tag">
            <img src="/images/logos/vmspark.svg" alt="VMSpark logo" />
          </div>

          <div
            class="inline-flex items-center gap-2 bg-coral/10 text-coral px-4 py-2 rounded-full mb-6 font-heading text-xs font-semibold border border-coral/20 uppercase tracking-wider"
          >
            <Icon name="ph:browsers-duotone" size={18} />
            Case study &middot; File no. 05
          </div>

          <p class="marker-label text-2xl md:text-3xl mb-4">from the workbench —</p>

          <h1
            class="font-display text-4xl sm:text-5xl md:text-6xl font-semibold text-navy leading-[1.05] tracking-tight mb-6"
          >
            A Rails shell,
            <br />
            <span class="relative inline-block">
              rebuilt for 2026
              <svg
                class="absolute -bottom-3 left-0 w-full"
                viewBox="0 0 520 14"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M3 9 Q 130 2 260 9 Q 390 16 517 7"
                  stroke="#E8573D"
                  stroke-width="3"
                  stroke-linecap="round"
                  opacity="0.55"
                />
              </svg>
            </span>
            <span class="text-coral">.</span>
          </h1>

          <p
            class="text-lg md:text-xl text-charcoal/70 max-w-2xl mx-auto font-body leading-relaxed mb-10"
          >
            A shell redesign for <WavyUnderline>VMSpark</WavyUnderline> — the multi-tenant
            pipeline that normalizes thousands of VMS jobs a day and fans them out to a dozen+
            ATS providers — raising the visual caliber of the admin app without touching the
            pipeline underneath.
          </p>

          <div class="border-t border-dashed border-coral/25 pt-6 mt-2">
            <dl
              class="grid grid-cols-2 md:grid-cols-4 gap-6 text-left md:text-center"
            >
              <div>
                <dt
                  class="font-heading text-[0.7rem] uppercase tracking-widest text-coral/70 mb-1"
                >
                  Role
                </dt>
                <dd class="font-display text-lg text-navy font-semibold">Design + Eng</dd>
              </div>
              <div>
                <dt
                  class="font-heading text-[0.7rem] uppercase tracking-widest text-coral/70 mb-1"
                >
                  Client
                </dt>
                <dd class="font-display text-lg text-navy font-semibold">VMSpark</dd>
              </div>
              <div>
                <dt
                  class="font-heading text-[0.7rem] uppercase tracking-widest text-coral/70 mb-1"
                >
                  Stack
                </dt>
                <dd class="font-display text-lg text-navy font-semibold">
                  Rails &middot; Hotwire
                </dd>
              </div>
              <div>
                <dt
                  class="font-heading text-[0.7rem] uppercase tracking-widest text-coral/70 mb-1"
                >
                  Focus
                </dt>
                <dd class="font-display text-lg text-navy font-semibold">
                  Shell &middot; Tokens
                </dd>
              </div>
            </dl>
          </div>
        </div>
      </article>
    </div>
  </section>

  <div class="squiggle-divider max-w-4xl mx-auto" aria-hidden="true"></div>

  <!-- ====== THE BRIEF ====== -->
  <section class="py-16 md:py-20 relative">
    <Blob tone="plum" size="lg" class="absolute top-10 right-6" animate="float-slow" opacity="opacity-10" />

    <div class="max-w-4xl mx-auto px-6 relative z-10">
      <div class="flex items-center gap-3 mb-6">
        <Icon name="ph:list-checks-duotone" size={28} class="text-sunset" />
        <h2 class="font-display text-2xl md:text-3xl text-navy font-semibold">On the docket</h2>
      </div>
      <div class="flex flex-wrap gap-3">
        <a
          href="#inventory"
          class="ingredient-chip hover:border-coral hover:text-coral transition-colors"
        >
          <Icon name="ph:magnifying-glass-duotone" size={18} class="text-coral" />
          Inventory before invention
        </a>
        <a
          href="#directions"
          class="ingredient-chip hover:border-coral hover:text-coral transition-colors"
        >
          <Icon name="ph:signpost-duotone" size={18} class="text-sunset" />
          Three directions, one chosen
        </a>
        <a
          href="#rollout"
          class="ingredient-chip hover:border-coral hover:text-coral transition-colors"
        >
          <Icon name="ph:stack-duotone" size={18} class="text-plum" />
          Phased rollout
        </a>
        <a
          href="#outcome"
          class="ingredient-chip hover:border-coral hover:text-coral transition-colors"
        >
          <Icon name="ph:trend-up-duotone" size={18} class="text-sage" />
          Outcome
        </a>
      </div>

      <p class="mt-10 text-lg md:text-xl text-charcoal/80 leading-relaxed font-body">
        VMSpark normalizes thousands of VMS job listings a day, runs them through an
        account-specific rule engine, and fans them out to whichever ATS the customer has
        contracted with. The product works. The shell it lived in did not look like it.
        Leadership was scheduling investor demos, and the admin app — the surface those
        conversations lived inside — felt like a Rails scaffold from 2018. Operators noticed
        it daily. Investors noticed it in the first thirty seconds of a demo.
      </p>
      <p class="mt-5 text-lg md:text-xl text-charcoal/80 leading-relaxed font-body">
        The brief I gave myself:
        <strong class="text-coral font-semibold"
          >make the shell read as a modern, enterprise-grade product that matches the
          sophistication of the pipeline underneath</strong
        >
        — without touching the pipeline, the rule engine, or anything an operator had muscle
        memory for.
      </p>
    </div>
  </section>

  <!-- ====== STEP 01 — INVENTORY ====== -->
  <section id="inventory" class="py-16 md:py-20 relative scroll-mt-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="flex items-start gap-6 mb-8">
        <span class="step-num" aria-hidden="true">01</span>
        <div>
          <p class="font-heading text-xs uppercase tracking-widest text-coral/70 mb-1">
            Step one
          </p>
          <h2
            class="font-display text-3xl md:text-4xl text-navy font-semibold leading-tight"
          >
            Inventory before invention
          </h2>
        </div>
      </div>

      <div class="space-y-5 text-charcoal/80 text-lg leading-relaxed font-body">
        <p>
          Before writing a line of new CSS, I cataloged what was there. The result was a
          <strong class="text-navy font-semibold">~700-line design inventory</strong>
          covering every one of the 350 ERB templates — roughly 11,800 lines — across the app.
        </p>
        <p>
          The audit wasn't a complaint list. It was the map that told me which problems were
          cosmetic (fixable during the redesign), which were structural (needed architectural
          decisions), and which were out of scope (pipeline-adjacent, don't touch). Most of
          what I found was UI sprawl: the same interaction rendered a dozen different ways
          across the app, each screen a small argument against the one before it.
        </p>
      </div>

      <!-- findings ledger -->
      <div
        class="mt-10 bg-white rounded-3xl p-7 md:p-9 border border-charcoal/5 shadow-sm relative"
        style="transform: rotate(-0.3deg)"
      >
        <div
          class="absolute -top-4 left-8 sticker bg-coral/10 text-coral border-coral/40"
          style="transform: rotate(-3deg)"
        >
          <Icon name="ph:notepad-duotone" size={14} class="mr-1" />
          A few of the findings
        </div>

        <div class="mt-4">
          {findings.map((f) => (
            <div class="finding-row">
              <span class="finding-count" aria-hidden="true">{f.count}</span>
              <div>
                <h3 class="font-display text-lg text-navy font-semibold mb-1">{f.title}</h3>
                <p class="text-charcoal/70 text-base" set:html={f.body} />
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- UI sprawl gallery -->
      <div class="mt-16">
        <div class="flex items-start gap-3 mb-3">
          <Icon name="ph:images-duotone" size={26} class="text-plum mt-1 flex-shrink-0" />
          <h3
            class="font-display text-xl md:text-2xl text-navy font-semibold leading-tight"
          >
            What the sprawl actually looked like
          </h3>
        </div>
        <p class="text-charcoal/75 leading-relaxed font-body mb-10 max-w-2xl">
          Four screens pulled from the same app, on the same day. Each one makes its own
          decisions about buttons, inputs, labels, and tables — and none of them agree with
          the others.
        </p>

        <div class="grid md:grid-cols-2 gap-10 md:gap-12">
          {sprawlImages.map((img) => (
            <figure class="relative" style={`transform: rotate(${img.rotate})`}>
              <span class="tape" style={img.tape} aria-hidden="true"></span>
              <div
                class="bg-white rounded-xl overflow-hidden border border-charcoal/10 shadow-md"
              >
                <img
                  src={img.src}
                  alt={img.alt}
                  class="w-full h-auto block"
                  loading="lazy"
                />
              </div>
              <figcaption
                class="mt-4 text-sm text-charcoal/70 font-body leading-relaxed"
                set:html={img.caption}
              />
            </figure>
          ))}
        </div>
      </div>

      <div class="mt-12 space-y-5 text-charcoal/80 text-lg leading-relaxed font-body">
        <p>
          With the inventory in hand, I could fix the UI sprawl at the root rather than one
          screen at a time. Buttons collapsed to a single set of component classes. Form
          inputs, selects, and labels moved onto shared primitives with consistent padding,
          focus states, and required-field treatment. Tables standardized on one header
          style, one pagination component, one density rule. Each fix cascaded across dozens
          of views because the semantic token layer was already in place — I just needed the
          views to route through it.
        </p>
      </div>
    </div>
  </section>

  <!-- ====== STEP 02 — DIRECTIONS ====== -->
  <section id="directions" class="py-16 md:py-20 relative scroll-mt-24">
    <div
      class="absolute bottom-20 left-6 w-16 h-16 bg-sunset/20 rounded-full animate-float"
      aria-hidden="true"
    ></div>
    <div class="max-w-5xl mx-auto px-6 relative z-10">
      <div class="flex items-start gap-6 mb-8">
        <span class="step-num" aria-hidden="true">02</span>
        <div>
          <p class="font-heading text-xs uppercase tracking-widest text-coral/70 mb-1">
            Step two
          </p>
          <h2
            class="font-display text-3xl md:text-4xl text-navy font-semibold leading-tight"
          >
            Three directions, one chosen
          </h2>
        </div>
      </div>

      <div class="max-w-3xl space-y-5 text-charcoal/80 text-lg leading-relaxed font-body">
        <p>
          Rather than design in a vacuum, I spec'd three mutually exclusive directions with
          honest tradeoffs. Writing the options down — with their reasons and risks — is what
          lets the choice get overturned on evidence later, not preference.
        </p>
      </div>

      <div class="mt-10 grid md:grid-cols-3 gap-6 items-stretch">
        <!-- A — Command Shell -->
        <div class="direction-card" style="transform: rotate(-0.8deg)">
          <div
            class="inline-flex items-center gap-2 text-plum font-heading text-xs font-semibold uppercase tracking-wider mb-2"
          >
            <span
              class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-plum/10"
              >A</span
            >
            Command Shell
          </div>
          <p class="text-sm text-charcoal/50 font-body mb-3">
            Dense &middot; Keyboard-first
          </p>
          <p class="text-charcoal/70 text-base leading-relaxed">
            56 px icon rail, tight 13/14 px type, hairline borders,
            <code class="font-mono text-plum text-sm">⌘K</code> palette as the centerpiece,
            orange reserved for exactly one thing per screen.
          </p>
          <p class="mt-4 text-sm font-heading text-plum/80">
            <Icon name="ph:target-duotone" size={14} class="mr-1 align-middle" />
            Signals &ldquo;scales to power users.&rdquo;
          </p>
        </div>

        <!-- B — Two-Tier Platform (CHOSEN) -->
        <div class="direction-card direction-card--chosen" style="transform: rotate(0.3deg)">
          <div
            class="absolute -top-3 right-5 text-coral paper-stamp"
            aria-label="Chosen direction"
          >
            Chosen
          </div>
          <div
            class="inline-flex items-center gap-2 text-coral font-heading text-xs font-semibold uppercase tracking-wider mb-2"
          >
            <span
              class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-coral/15"
              >B</span
            >
            Two-Tier Platform
          </div>
          <p class="text-sm text-charcoal/50 font-body mb-3">Enterprise-familiar</p>
          <p class="text-charcoal/75 text-base leading-relaxed">
            48 px product rail plus 260 px project nav — the real two-tier pattern.
            App-switcher waffle, breadcrumbed page headers, right-side inspector panel. Brand
            orange on active rail state, soft navy-tinted elevation.
          </p>
          <p class="mt-4 text-sm font-heading text-coral">
            <Icon name="ph:users-three-duotone" size={14} class="mr-1 align-middle" />
            Every enterprise buyer has used this pattern before.
          </p>
        </div>

        <!-- C — Modern Workspace -->
        <div class="direction-card" style="transform: rotate(-0.2deg)">
          <div
            class="inline-flex items-center gap-2 text-sky font-heading text-xs font-semibold uppercase tracking-wider mb-2"
          >
            <span
              class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-sky/15"
              >C</span
            >
            Modern Workspace
          </div>
          <p class="text-sm text-charcoal/50 font-body mb-3">
            Spacious &middot; Document-forward
          </p>
          <p class="text-charcoal/70 text-base leading-relaxed">
            270 px soft sidebar, no persistent top bar,
            <code class="font-mono text-plum text-sm">⌘K</code> by shortcut only, generous
            spacing.
          </p>
          <p class="mt-4 text-sm font-heading text-sky/80">
            <Icon name="ph:warning-duotone" size={14} class="mr-1 align-middle" />
            Risk: reads as lightweight for a dense ops tool.
          </p>
        </div>
      </div>

      <div
        class="mt-10 max-w-3xl space-y-5 text-charcoal/80 text-lg leading-relaxed font-body"
      >
        <p>
          I chose B. Not because it was the prettiest (C was), and not because it was the
          most sophisticated (A was). I chose it because the product's audience was
          multi-tenant operators, and the lowest-risk path to both user and investor trust
          was the pattern those operators had already used at every previous job.
        </p>
        <p>
          I also <strong class="text-navy font-semibold">dropped</strong> a feature I'd
          originally scoped in: a global "Create" button. Most creates in this product are
          feed-driven, not user-initiated. Adding one would have been copying a convention
          without earning it.
        </p>
      </div>

      <!-- pull quote -->
      <figure
        class="mt-12 bg-coral/5 border-l-4 border-coral rounded-r-2xl p-6 md:p-8 relative max-w-3xl"
        style="transform: rotate(-0.3deg)"
      >
        <Icon
          name="ph:quotes-duotone"
          size={32}
          class="text-coral/60 absolute -top-3 left-6 bg-cream px-1"
        />
        <blockquote class="pull-quote text-xl md:text-2xl text-navy leading-snug">
          Pattern familiarity compounds trust faster than novelty does.
        </blockquote>
      </figure>
    </div>
  </section>

  <!-- ====== STEP 03 — ROLLOUT ====== -->
  <section id="rollout" class="py-16 md:py-20 relative scroll-mt-24">
    <div
      class="absolute top-10 right-6 w-20 h-20 bg-lemon/50 blob-shape animate-float-slow"
      aria-hidden="true"
    ></div>
    <div class="max-w-5xl mx-auto px-6 relative z-10">
      <div class="flex items-start gap-6 mb-8">
        <span class="step-num" aria-hidden="true">03</span>
        <div>
          <p class="font-heading text-xs uppercase tracking-widest text-coral/70 mb-1">
